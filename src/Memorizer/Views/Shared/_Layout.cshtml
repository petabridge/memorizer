<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Memorizer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link id="prism-theme" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet">
    <!-- Theme variables must come before other custom CSS -->
    <link href="~/css/theme-variables.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
    <link href="~/css/markdown-content.css" rel="stylesheet">
    <link href="~/css/tools.css" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
    <!-- Theme switcher in head to prevent flash of unstyled content -->
    <script src="~/js/theme-switcher.js"></script>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <h4 class="text-white">
                            <i class="fas fa-brain me-2"></i>
                            Memorizer
                        </h4>
                        <p class="text-white-50 small">Memory Management System</p>
                    </div>

                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="fas fa-list me-2"></i>
                                All Memories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               asp-controller="Home" asp-action="Create">
                                <i class="fas fa-plus me-2"></i>
                                Create Memory
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tools" ? "active" : "")"
                               asp-controller="Tools" asp-action="Index">
                                <i class="fas fa-tools me-2"></i>
                                Tools
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Stats" ? "active" : "")"
                               asp-controller="Home" asp-action="Stats">
                                <i class="fas fa-chart-bar me-2"></i>
                                Statistics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "McpConfig" ? "active" : "")"
                               asp-controller="Home" asp-action="McpConfig">
                                <i class="fas fa-cog me-2"></i>
                                MCP Config
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Config" ? "active" : "")"
                               asp-controller="Home" asp-action="Config">
                                <i class="fas fa-cogs me-2"></i>
                                System Config
                            </a>
                        </li>
                    </ul>

                    <!-- Theme Toggle -->
                    <div class="d-flex justify-content-center align-items-center my-3">
                        <i class="fas fa-sun text-white-50 me-2"></i>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch"
                                   id="themeSwitch" onchange="ThemeSwitcher.toggle()">
                        </div>
                        <i class="fas fa-moon text-white-50 ms-1"></i>
                    </div>

                    <hr class="my-4" style="border-color: var(--sidebar-divider);">

                    <div class="text-center">
                        <small class="text-white-50">
                            <i class="fas fa-database me-1"></i>
                            PostgreSQL + pgvector
                        </small>
                    </div>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-wrapper">
                @await Html.PartialAsync("_DimensionMismatchWarning")
                <div class="py-4">
                    @RenderBody()
                </div>

                <!-- Footer with attribution -->
                <footer class="mt-auto py-3 border-top">
                    <div class="text-center">
                        <div class="mb-1">
                            <small class="text-muted">
                                Made with ❤️ by <a href="https://petabridge.com/" target="_blank" class="text-decoration-none">Petabridge</a>
                            </small>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">
                                originally forked from <a href="https://dario.griffo.io/" target="_blank" class="text-decoration-none">Dario Griffo</a>'s <a href="https://github.com/dariogriffo/postg-mem" target="_blank" class="text-decoration-none"><code>postg-mem</code></a> server
                            </small>
                        </div>
                        <div>
                            <small class="text-muted">
                                <a href="https://github.com/petabridge/memorizer-v1">Memorizer</a> v@(System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "Unknown")
                            </small>
                        </div>
                    </div>
                </footer>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script src="~/js/memory-utils.js"></script>
    <script src="~/js/progress-stream.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
