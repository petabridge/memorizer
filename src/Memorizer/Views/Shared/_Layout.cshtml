<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Memorizer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link id="prism-theme" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet">
    <!-- Theme variables must come before other custom CSS -->
    <link href="~/css/theme-variables.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/markdown-content.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/tools.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/workspace-tree.css" rel="stylesheet" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
    <!-- Theme switcher in head to prevent flash of unstyled content -->
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-3">
                        <h4 class="text-white">
                            <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">
                                <i class="fas fa-brain me-2"></i>
                                Memorizer
                            </a>
                        </h4>
                        <p class="text-white-50 small mb-0">Memory Management System</p>
                    </div>

                    <!-- Search Bar -->
                    <div class="px-3 mb-2">
                        <form action="/memories" method="get" class="d-flex">
                            <div class="input-group input-group-sm">
                                <input type="text" name="q" class="form-control sidebar-search-input"
                                       placeholder="Search memories..." aria-label="Search memories">
                                <button class="btn sidebar-search-btn" type="submit">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Primary Actions -->
                    <div class="d-flex gap-2 px-3 mb-3">
                        <a class="btn btn-sm btn-outline-light flex-grow-1"
                           asp-controller="Home" asp-action="Memories">
                            <i class="fas fa-clock me-1"></i>
                            Recent
                        </a>
                        <a class="btn btn-sm btn-outline-light flex-grow-1"
                           asp-controller="Home" asp-action="Create">
                            <i class="fas fa-plus me-1"></i>
                            New
                        </a>
                        <!-- Settings Dropdown -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    title="Settings & Tools">
                                <i class="fas fa-cog"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Tools" asp-action="Index">
                                        <i class="fas fa-tools me-2"></i>Tools
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Stats">
                                        <i class="fas fa-chart-bar me-2"></i>Statistics
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="McpConfig">
                                        <i class="fas fa-cog me-2"></i>MCP Config
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Config">
                                        <i class="fas fa-cogs me-2"></i>System Config
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Settings" asp-action="Providers">
                                        <i class="fas fa-plug me-2"></i>LLM Config
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <hr class="my-2" style="border-color: var(--sidebar-divider);">

                    <!-- Workspace/Project Tree Navigation (Primary) -->
                    @await Html.PartialAsync("_WorkspaceTree")

                    <hr class="my-3" style="border-color: var(--sidebar-divider);">

                    <!-- Theme Toggle -->
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <i class="fas fa-sun text-white-50 me-2"></i>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch"
                                   id="themeSwitch" onchange="ThemeSwitcher.toggle()">
                        </div>
                        <i class="fas fa-moon text-white-50 ms-1"></i>
                    </div>

                    <div class="text-center">
                        <small class="text-white-50">
                            <i class="fas fa-database me-1"></i>
                            PostgreSQL + pgvector
                        </small>
                    </div>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 content-wrapper">
                @await Html.PartialAsync("_DimensionMismatchWarning")
                <div class="py-4">
                    @RenderBody()
                </div>

                <!-- Footer with attribution -->
                <footer class="mt-auto py-3 border-top">
                    <div class="text-center">
                        <div class="mb-1">
                            <small class="text-muted">
                                Made with ❤️ by <a href="https://petabridge.com/" target="_blank" class="text-decoration-none">Petabridge</a>
                            </small>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">
                                originally forked from <a href="https://dario.griffo.io/" target="_blank" class="text-decoration-none">Dario Griffo</a>'s <a href="https://github.com/dariogriffo/postg-mem" target="_blank" class="text-decoration-none"><code>postg-mem</code></a> server
                            </small>
                        </div>
                        <div>
                            <small class="text-muted">
                                <a href="https://github.com/petabridge/memorizer-v1">Memorizer</a> v@(System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "Unknown")
                            </small>
                        </div>
                    </div>
                </footer>
            </main>
        </div>
    </div>

    <!-- Create Workspace Modal (from sidebar) -->
    <div class="modal fade" id="createWorkspaceFromSidebarModal" tabindex="-1" aria-labelledby="createWorkspaceFromSidebarModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createWorkspaceFromSidebarModalLabel">
                        <i class="fas fa-folder-plus me-2"></i>
                        Create Workspace
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createWorkspaceFromSidebarForm" onsubmit="event.preventDefault(); WorkspaceTree.createWorkspace();">
                        <div class="mb-3">
                            <label for="sidebarWorkspaceName" class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="sidebarWorkspaceName" placeholder="e.g., Engineering, Marketing" required>
                            <div class="form-text">A unique name for your workspace</div>
                        </div>
                        <div class="mb-3">
                            <label for="sidebarWorkspaceDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="sidebarWorkspaceDescription" rows="3" placeholder="Optional description of this workspace's purpose"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="sidebarCreateWorkspaceBtn" onclick="WorkspaceTree.createWorkspace()">
                        <i class="fas fa-plus me-2"></i>
                        Create Workspace
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script src="~/js/memory-utils.js" asp-append-version="true"></script>
    <script src="~/js/progress-stream.js" asp-append-version="true"></script>
    <script src="~/js/workspace-tree.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
