@{
    ViewData["Title"] = "Markdown Export Tool";
    var isEnabled = (bool)ViewData["IsEnabled"]!;
    var rootPath = (string)ViewData["RootPath"]!;
}

<div class="container-fluid markdown-export-page">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Tools")">Tools</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Markdown Export</li>
                </ol>
            </nav>

            <h1 class="mb-4">
                <i class="fas fa-file-export me-2"></i>
                Markdown Export Tool
            </h1>
            <p class="lead">Export memories as Markdown files with YAML frontmatter to the filesystem.</p>
        </div>
    </div>

    @if (!isEnabled)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-warning" role="alert">
                    <h6><i class="fas fa-exclamation-triangle me-2"></i>Feature Not Configured</h6>
                    <p class="mb-0">
                        Markdown export is disabled. Set <code>MarkdownExport:RootPath</code> in your configuration
                        or the <code>MEMORIZER_MarkdownExport__RootPath</code> environment variable to enable it.
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Export Memories</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Configuration Status</label>
                        <div>
                            @if (isEnabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                            <span class="ms-2 text-body-secondary small">Root path: <code>@rootPath</code></span>
                        </div>
                    </div>

                    <form id="markdownExportForm">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                            <button type="submit" class="btn btn-primary" id="startButton" @(isEnabled ? "" : "disabled")>
                                <i class="fas fa-file-export me-1"></i>
                                Start Export (All Memories)
                            </button>
                            <button type="button" class="btn btn-secondary" id="statusButton">
                                <i class="fas fa-info-circle me-1"></i>
                                Check Status
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Progress and Results -->
            <div class="card mt-4" id="progressCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Progress</h6>
                </div>
                <div class="card-body">
                    <div class="progress mb-3">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 0%"
                             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progressBar">
                            0%
                        </div>
                    </div>
                    <div id="progressText">Initializing...</div>
                </div>
            </div>

            <!-- Results -->
            <div class="card mt-4" id="resultsCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Results</h6>
                </div>
                <div class="card-body">
                    <div id="resultsContent">
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title mb-0">How It Works</h6>
                </div>
                <div class="card-body">
                    <ol class="list-group list-group-numbered list-group-flush">
                        <li class="list-group-item border-0 px-0">
                            <strong>Scan Memories</strong><br>
                            <small class="text-body-secondary">Iterate through all memories in the database</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Build Folder Structure</strong><br>
                            <small class="text-body-secondary">Create folders mirroring workspace/project hierarchy</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Generate Files</strong><br>
                            <small class="text-body-secondary">Write .md files with YAML frontmatter and memory content</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Report Results</strong><br>
                            <small class="text-body-secondary">Show export summary with success/failure counts</small>
                        </li>
                    </ol>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">File Format</h6>
                </div>
                <div class="card-body">
                    <p class="small text-body-secondary">Each memory is exported as:</p>
                    <pre class="small bg-body-tertiary p-2 rounded"><code>---
title: "Memory Title"
id: a1b2c3d4-...
type: reference
tags:
  - tag1
  - tag2
confidence: 0.95
source: LLM
archetype: document
version: 3
created: 2026-03-04T12:00:00Z
updated: 2026-03-04T14:30:00Z
---

Memory content as markdown...</code></pre>
                    <p class="small text-body-secondary mb-0">
                        Filename: <code>{title-slug}--{short-id}.md</code>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const progressClient = new ProgressStreamClient({
            sseUrl: '/tools/markdown-export-progress',
            progressBarId: 'progressBar',
            progressTextId: 'progressText',
            progressCardId: 'progressCard',
            resultsCardId: 'resultsCard',
            resultsContentId: 'resultsContent',
            startButtonId: 'startButton',
            formId: 'markdownExportForm',
            jobName: 'Markdown export'
        });

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('markdownExportForm').addEventListener('submit', function(e) {
                e.preventDefault();
                startExport();
            });

            document.getElementById('statusButton').addEventListener('click', function() {
                checkStatus();
            });
        });

        function startExport() {
            progressClient.disableStartButton();
            progressClient.showProgressCard();
            progressClient.updateProgress(0, 'Starting markdown export...');

            fetch('@Url.Action("StartMarkdownExport", "Tools")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    progressClient.showAlert('success', data.message);
                    progressClient.updateProgress(10, 'Markdown export started. Processing...');
                    progressClient.start();
                } else {
                    progressClient.showAlert('danger', data.message);
                    progressClient.enableStartButton();
                    progressClient.hideProgressCard();
                }
            })
            .catch(error => {
                progressClient.showAlert('danger', 'Failed to start markdown export. Please try again.');
                progressClient.enableStartButton();
                progressClient.hideProgressCard();
            });
        }

        function checkStatus() {
            fetch('@Url.Action("GetMarkdownExportStatus", "Tools")')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        let msg = 'Status: ' + data.status;
                        if (data.isRunning) {
                            msg += ' ' + ProgressStreamClient.formatProgressDetails(data);
                        }
                        progressClient.showAlert('info', msg);
                    } else {
                        progressClient.showAlert('warning', data.message);
                    }
                })
                .catch(error => {
                    progressClient.showAlert('danger', 'Failed to get status.');
                });
        }
    </script>
}
