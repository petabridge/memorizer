@{
    ViewData["Title"] = "Tools";
}

<div class="container-fluid tools-page">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Memory Management Tools</h1>
            <p class="lead">Tools to maintain and improve your memory database.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-heading me-2"></i>
                        Title Generation
                    </h5>
                    <p class="card-text">
                        Automatically generate descriptive titles for memories that don't have them using AI.
                    </p>
                    <p class="text-muted small">
                        This tool will scan your memory database for entries without titles and use the configured LLM to generate meaningful titles based on the content.
                    </p>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("TitleGeneration", "Tools")" class="btn btn-primary">
                        <i class="fas fa-magic me-1"></i>
                        Generate Titles
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-sync-alt me-2"></i>
                        Embedding Regeneration
                    </h5>
                    <p class="card-text">
                        Regenerate all embeddings when dimensions or embedding model changes.
                    </p>
                    <p class="text-muted small">
                        This tool regenerates both content and metadata embeddings for all memories. Use after changing embedding dimensions or switching models.
                    </p>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("EmbeddingRegeneration", "Tools")" class="btn btn-primary">
                        <i class="fas fa-sync me-1"></i>
                        Regenerate Embeddings
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-trash-alt me-2"></i>
                        Version Purge
                    </h5>
                    <p class="card-text">
                        Clean up old version snapshots to reclaim storage space.
                    </p>
                    <p class="text-muted small">
                        Purge version snapshots older than a specified age. Always preserves the latest version of each memory.
                    </p>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("VersionPurge", "Tools")" class="btn btn-warning">
                        <i class="fas fa-broom me-1"></i>
                        Purge Versions
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-expand-arrows-alt me-2"></i>
                        Dimension Migration
                    </h5>
                    <p class="card-text">
                        Migrate embedding dimensions when changing to a different model.
                    </p>
                    <p class="text-muted small">
                        Use when switching to an embedding model with different output dimensions (e.g., from 384 to 768). Handles schema changes and embedding regeneration.
                    </p>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("DimensionMigration", "Tools")" class="btn btn-danger">
                        <i class="fas fa-database me-1"></i>
                        Migrate Dimensions
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-chart-bar me-2"></i>
                        Performance Analytics
                    </h5>
                    <p class="card-text">
                        View analytics and performance metrics for automated tools.
                    </p>
                    <p class="text-muted small">
                        Coming soon: Track how tools perform, success rates, and processing times.
                    </p>
                </div>
                <div class="card-footer">
                    <button class="btn btn-secondary" disabled>
                        <i class="fas fa-clock me-1"></i>
                        Coming Soon
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-search me-2"></i>
                        Memory Maintenance
                    </h5>
                    <p class="card-text">
                        Find and fix issues with your memory database.
                    </p>
                    <p class="text-muted small">
                        Coming soon: Detect orphaned chunks, broken relationships, and other data quality issues.
                    </p>
                </div>
                <div class="card-footer">
                    <button class="btn btn-secondary" disabled>
                        <i class="fas fa-clock me-1"></i>
                        Coming Soon
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="alert alert-info">
                <h6><i class="fas fa-info-circle me-2"></i>About These Tools</h6>
                <p class="mb-0">
                    These tools run in the background using Akka.NET actors to process your memory database safely and efficiently. 
                    All operations are logged and can be monitored for progress and results.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh status indicators if needed
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Tools page loaded');
        });
    </script>
} 