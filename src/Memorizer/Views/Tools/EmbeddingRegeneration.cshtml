@{
    ViewData["Title"] = "Embedding Regeneration Tool";
}

<div class="container-fluid embedding-regeneration-page">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Tools")">Tools</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Embedding Regeneration</li>
                </ol>
            </nav>

            <h1 class="mb-4">
                <i class="fas fa-sync-alt me-2"></i>
                Embedding Regeneration Tool
            </h1>
            <p class="lead">Regenerate all embeddings (content + metadata) for all memories when embedding dimensions or model changes.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Run Embedding Regeneration</h5>
                </div>
                <div class="card-body">
                    <form id="embeddingRegenerationForm">
                        <div class="mb-3">
                            <label for="pageSize" class="form-label">Page Size</label>
                            <input type="number" class="form-control" id="pageSize" name="pageSize"
                                   value="100" min="1" max="1000" required>
                            <div class="form-text">
                                Number of memories to process per page (1-1000). Larger pages may use more memory but process faster.
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                            <button type="submit" class="btn btn-primary" id="startButton">
                                <i class="fas fa-play me-1"></i>
                                Start Embedding Regeneration
                            </button>
                            <button type="button" class="btn btn-secondary" id="statusButton">
                                <i class="fas fa-info-circle me-1"></i>
                                Check Status
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Progress and Results -->
            <div class="card mt-4" id="progressCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Progress</h6>
                </div>
                <div class="card-body">
                    <div class="progress mb-3">
                        <div class="progress-bar" role="progressbar" style="width: 0%"
                             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progressBar">
                            0%
                        </div>
                    </div>
                    <div id="progressText">Initializing...</div>
                </div>
            </div>

            <!-- Results -->
            <div class="card mt-4" id="resultsCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Results</h6>
                </div>
                <div class="card-body">
                    <div id="resultsContent">
                        <!-- Results will be populated here -->
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title mb-0">How It Works</h6>
                </div>
                <div class="card-body">
                    <ol class="list-group list-group-numbered list-group-flush">
                        <li class="list-group-item border-0 px-0">
                            <strong>Paginate Memories</strong><br>
                            <small class="text-muted">Process all memories in configurable page sizes</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Regenerate Content Embedding</strong><br>
                            <small class="text-muted">Re-embed title + text content for semantic search</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Regenerate Metadata Embedding</strong><br>
                            <small class="text-muted">Re-embed title + tags for metadata search</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Update Records</strong><br>
                            <small class="text-muted">Store both new embeddings in a single DB transaction</small>
                        </li>
                    </ol>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">When to Use</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-primary" role="alert">
                        <small>
                            <i class="fas fa-ruler me-1"></i>
                            <strong>Dimensions Changed:</strong> Use this tool after changing the <code>Embeddings:Dimensions</code> configuration value.
                        </small>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <small>
                            <i class="fas fa-brain me-1"></i>
                            <strong>Model Changed:</strong> Use after switching to a different embedding model that produces different vector representations.
                        </small>
                    </div>
                    <div class="alert alert-warning" role="alert">
                        <small>
                            <i class="fas fa-clock me-1"></i>
                            <strong>Time Warning:</strong> This operation processes ALL memories and may take significant time for large databases.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Create progress stream client for embedding regeneration
        const progressClient = new ProgressStreamClient({
            sseUrl: '/ui/tools/embedding-regeneration-progress',
            progressBarId: 'progressBar',
            progressTextId: 'progressText',
            progressCardId: 'progressCard',
            resultsCardId: 'resultsCard',
            resultsContentId: 'resultsContent',
            startButtonId: 'startButton',
            formId: 'embeddingRegenerationForm',
            jobName: 'Embedding regeneration'
        });

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('embeddingRegenerationForm').addEventListener('submit', function(e) {
                e.preventDefault();
                startEmbeddingRegeneration();
            });

            document.getElementById('statusButton').addEventListener('click', function() {
                checkStatus();
            });
        });

        function startEmbeddingRegeneration() {
            const pageSize = document.getElementById('pageSize').value;

            // Disable form and show progress
            progressClient.disableStartButton();
            progressClient.showProgressCard();
            progressClient.updateProgress(0, 'Starting embedding regeneration...');

            const formData = new FormData();
            formData.append('pageSize', pageSize);

            fetch('@Url.Action("StartEmbeddingRegeneration", "Tools")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    progressClient.showAlert('success', data.message);
                    progressClient.updateProgress(10, 'Embedding regeneration started. Processing...');
                    // Start SSE progress stream
                    progressClient.start();
                } else {
                    if (data.status === 'running') {
                        progressClient.showAlert('warning', 'A batch job is already running. Please wait for it to finish. ' + ProgressStreamClient.formatProgressDetails(data));
                        progressClient.disableStartButton();
                        progressClient.showProgressCard();
                        progressClient.updateProgress(10, 'Batch already in progress...');
                        progressClient.start();
                    } else {
                        progressClient.showAlert('danger', data.message);
                        progressClient.enableStartButton();
                        progressClient.hideProgressCard();
                    }
                }
            })
            .catch(error => {
                progressClient.showAlert('danger', 'Failed to start embedding regeneration. Please try again.');
                progressClient.enableStartButton();
                progressClient.hideProgressCard();
            });
        }

        function checkStatus() {
            fetch('@Url.Action("GetEmbeddingRegenerationStatus", "Tools")')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        let msg = 'Status: ' + data.status;
                        if (data.isRunning) {
                            msg += ' (Job in progress) ' + ProgressStreamClient.formatProgressDetails(data);
                            progressClient.disableStartButton();
                        } else {
                            msg += ' (Idle)';
                            progressClient.enableStartButton();
                        }
                        progressClient.showAlert('info', msg);
                    } else {
                        progressClient.showAlert('warning', data.message);
                    }
                })
                .catch(error => {
                    progressClient.showAlert('danger', 'Failed to get status.');
                });
        }
    </script>
}
