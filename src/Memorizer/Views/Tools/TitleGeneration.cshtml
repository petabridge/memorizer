@{
    ViewData["Title"] = "Title Generation Tool";
}

<div class="container-fluid title-generation-page">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Tools")">Tools</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Title Generation</li>
                </ol>
            </nav>
            
            <h1 class="mb-4">
                <i class="fas fa-heading me-2"></i>
                Title Generation Tool
            </h1>
            <p class="lead">Generate descriptive titles for memories that don't have them.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- LLM Configuration Status -->
            <div class="card" id="configStatusCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0 text-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        LLM Configuration Required
                    </h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <strong>Title generation requires LLM configuration.</strong>
                        <p class="mb-2 mt-2" id="configReason">Checking configuration...</p>
                        <details class="mt-3">
                            <summary class="fw-bold">Configuration Help</summary>
                            <div class="mt-2">
                                <p>Add the following to your <code>appsettings.json</code>:</p>
                                <pre class="bg-light p-2 rounded"><code>{
  "LLM": {
    "ApiUrl": "http://localhost:11434",
    "Model": "llama3",
    "Timeout": "00:02:00"
  }
}</code></pre>
                                <p class="mt-2">
                                    <strong>Requirements:</strong>
                                </p>
                                <ul>
                                    <li>Install and run <a href="https://ollama.ai/" target="_blank">Ollama</a> or compatible LLM service</li>
                                    <li>Pull a model: <code>ollama pull llama3</code></li>
                                    <li>Configure the API URL and model name in settings</li>
                                </ul>
                            </div>
                        </details>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Run Title Generation</h5>
                </div>
                <div class="card-body">
                    <form id="titleGenerationForm">
                        <div class="mb-3">
                            <label for="batchSize" class="form-label">Batch Size</label>
                            <input type="number" class="form-control" id="batchSize" name="batchSize" 
                                   value="50" min="1" max="500" required>
                            <div class="form-text">
                                Number of memories to process in this batch (1-500). Start with smaller batches to test.
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                            <button type="submit" class="btn btn-primary" id="startButton">
                                <i class="fas fa-play me-1"></i>
                                Start Title Generation
                            </button>
                            <button type="button" class="btn btn-secondary" id="statusButton">
                                <i class="fas fa-info-circle me-1"></i>
                                Check Status
                            </button>
                            <button type="button" class="btn btn-outline-info" id="checkConfigButton">
                                <i class="fas fa-cog me-1"></i>
                                Check LLM Config
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Progress and Results -->
            <div class="card mt-4" id="progressCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Progress</h6>
                </div>
                <div class="card-body">
                    <div class="progress mb-3">
                        <div class="progress-bar" role="progressbar" style="width: 0%" 
                             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progressBar">
                            0%
                        </div>
                    </div>
                    <div id="progressText">Initializing...</div>
                </div>
            </div>

            <!-- Results -->
            <div class="card mt-4" id="resultsCard" style="display: none;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Results</h6>
                </div>
                <div class="card-body">
                    <div id="resultsContent">
                        <!-- Results will be populated here -->
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title mb-0">How It Works</h6>
                </div>
                <div class="card-body">
                    <ol class="list-group list-group-numbered list-group-flush">
                        <li class="list-group-item border-0 px-0">
                            <strong>Scan Database</strong><br>
                            <small class="text-muted">Find memories without titles</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>AI Analysis</strong><br>
                            <small class="text-muted">Use LLM to analyze content and generate titles</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Update Records</strong><br>
                            <small class="text-muted">Apply generated titles to memories</small>
                        </li>
                        <li class="list-group-item border-0 px-0">
                            <strong>Report Results</strong><br>
                            <small class="text-muted">Show success/failure statistics</small>
                        </li>
                    </ol>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">Important Notes</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <small>
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            <strong>LLM Required:</strong> This tool requires a configured LLM service (like Ollama) to generate titles.
                        </small>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <small>
                            <i class="fas fa-info-circle me-1"></i>
                            <strong>Background Processing:</strong> Title generation runs in the background and may take time depending on batch size.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Check LLM configuration when page loads
            checkLLMConfiguration();

            document.getElementById('titleGenerationForm').addEventListener('submit', function(e) {
                e.preventDefault();
                startTitleGeneration();
            });

            document.getElementById('statusButton').addEventListener('click', function() {
                checkStatus();
            });

            document.getElementById('checkConfigButton').addEventListener('click', function() {
                checkLLMConfiguration();
            });
        });

        function startTitleGeneration() {
            const batchSize = document.getElementById('batchSize').value;
            const startButton = document.getElementById('startButton');
            const progressCard = document.getElementById('progressCard');
            
            // Disable form and show progress
            startButton.disabled = true;
            progressCard.style.display = 'block';
            updateProgress(0, 'Starting title generation...');
            
            fetch('@Url.Action("StartTitleGeneration", "Tools")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'batchSize=' + encodeURIComponent(batchSize)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAlert('success', data.message);
                    updateProgress(10, 'Title generation started. Processing...');
                    // Start polling for status
                    startStatusPolling();
                } else {
                    if (data.requiresConfiguration) {
                        showAlert('warning', data.message);
                        checkLLMConfiguration(); // Refresh config status
                    } else {
                        showAlert('danger', data.message);
                    }
                    startButton.disabled = false;
                    progressCard.style.display = 'none';
                }
            })
            .catch(error => {
                showAlert('danger', 'Failed to start title generation. Please try again.');
                startButton.disabled = false;
                progressCard.style.display = 'none';
            });
        }

        function checkStatus() {
            fetch('@Url.Action("GetTitleGenerationStatus", "Tools")')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showAlert('info', 'Status: ' + data.status + ' - ' + data.message);
                    } else {
                        showAlert('warning', data.message);
                    }
                })
                .catch(error => {
                    showAlert('danger', 'Failed to get status.');
                });
        }

        function checkLLMConfiguration() {
            fetch('@Url.Action("GetLlmStatus", "Tools")')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const configCard = document.getElementById('configStatusCard');
                        const configReason = document.getElementById('configReason');
                        const startButton = document.getElementById('startButton');
                        const form = document.getElementById('titleGenerationForm');

                        if (data.isConfigured) {
                            // LLM is properly configured
                            configCard.style.display = 'none';
                            startButton.disabled = false;
                            const inputs = form.querySelectorAll('input, button');
                            inputs.forEach(input => input.disabled = false);
                            showAlert('success', `LLM is configured (Model: ${data.model})`);
                        } else {
                            // LLM needs configuration
                            configReason.textContent = data.reason;
                            configCard.style.display = 'block';
                            startButton.disabled = true;
                            
                            // Show current configuration details
                            let configDetails = `Current settings: Model="${data.model}", API="${data.apiUrl}"`;
                            configReason.innerHTML = data.reason + '<br><small class="text-muted">' + configDetails + '</small>';
                        }
                    } else {
                        showAlert('danger', 'Failed to check LLM configuration: ' + data.message);
                    }
                })
                .catch(error => {
                    showAlert('danger', 'Failed to check LLM configuration.');
                    document.getElementById('configStatusCard').style.display = 'block';
                    document.getElementById('configReason').textContent = 'Unable to connect to server to check configuration.';
                    document.getElementById('startButton').disabled = true;
                });
        }

        function startStatusPolling() {
            // TODO: Implement real-time status polling
            // For now, simulate progress
            let progress = 10;
            const interval = setInterval(function() {
                progress += 10;
                updateProgress(progress, `Processing... ${progress}% complete`);
                
                if (progress >= 100) {
                    clearInterval(interval);
                    updateProgress(100, 'Title generation completed!');
                    document.getElementById('startButton').disabled = false;
                    showResults('Sample results would appear here');
                }
            }, 2000);
        }

        function updateProgress(percent, text) {
            const progressBar = document.getElementById('progressBar');
            progressBar.style.width = percent + '%';
            progressBar.setAttribute('aria-valuenow', percent);
            progressBar.textContent = percent + '%';
            document.getElementById('progressText').textContent = text;
        }

        function showResults(content) {
            document.getElementById('resultsContent').innerHTML = content;
            document.getElementById('resultsCard').style.display = 'block';
        }

        function showAlert(type, message) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            
            // Remove existing alerts
            const existingAlerts = document.querySelectorAll('.alert');
            existingAlerts.forEach(alert => alert.remove());
            
            // Add new alert at the top of the form
            const form = document.getElementById('titleGenerationForm');
            form.insertAdjacentHTML('afterbegin', alertHtml);
            
            // Auto-dismiss after 5 seconds for non-danger alerts
            if (type !== 'danger') {
                setTimeout(function() {
                    const alert = document.querySelector('.alert');
                    if (alert) {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }
                }, 5000);
            }
        }
    </script>
} 