@model Memorizer.Services.MemoryStats
@{
    ViewData["Title"] = "Statistics Dashboard";
}

<div class="mb-4">
    <h1 class="h3 mb-1">
        <i class="fas fa-chart-bar me-2 text-primary"></i>
        Statistics Dashboard
    </h1>
    <p class="text-muted mb-0">Overview of your Memorizer memory storage system</p>
</div>

@{
    string FormatBytes(long bytes)
    {
        if (bytes == 0) return "0 B";
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        int i = (int)Math.Floor(Math.Log(bytes) / Math.Log(1024));
        return $"{(bytes / Math.Pow(1024, i)):F2} {sizes[i]}";
    }
}

<div class="row mb-4">
    <!-- Total Memories Card -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-brain fa-3x text-primary"></i>
                </div>
                <h3 class="mb-1">@Model.TotalMemories.ToString("N0")</h3>
                <p class="text-muted mb-0">Total Memories</p>
            </div>
        </div>
    </div>

    <!-- Total Versions Card -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-history fa-3x text-success"></i>
                </div>
                <h3 class="mb-1">@Model.TotalVersions.ToString("N0")</h3>
                <p class="text-muted mb-0">Version Snapshots</p>
            </div>
        </div>
    </div>

    <!-- Audit Events Card -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-calendar-alt fa-3x text-info"></i>
                </div>
                <h3 class="mb-1">@Model.TotalAuditEvents.ToString("N0")</h3>
                <p class="text-muted mb-0">Audit Events</p>
            </div>
        </div>
    </div>

    <!-- Total Storage Card -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-database fa-3x text-warning"></i>
                </div>
                <h3 class="mb-1">@FormatBytes(Model.TotalStorageBytes)</h3>
                <p class="text-muted mb-0">Total Storage</p>
            </div>
        </div>
    </div>
</div>

<!-- Storage Breakdown Row -->
<div class="row mb-4">
    <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-hdd me-2"></i>
                    Storage Breakdown
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Memories + Embeddings</h6>
                            <p class="h4 mb-0">@FormatBytes(Model.MemoriesStorageBytes)</p>
                            <small class="text-muted">Includes content & vector data</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Versions + Events</h6>
                            <p class="h4 mb-0">@FormatBytes(Model.VersionStorageBytes)</p>
                            <small class="text-muted">History snapshots & audit log</small>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Average Memory Size</h6>
                            <p class="mb-0">@(Model.AverageMemorySizeBytes.ToString("N0")) bytes</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Vector Dimensions</h6>
                            <p class="mb-0">@(Model.EmbeddingDimensions)D</p>
                        </div>
                    </div>
                </div>
                @if (Model.TotalStorageBytes > 0)
                {
                    <div class="mt-3">
                        <small class="text-muted">Storage ratio: @(((double)Model.VersionStorageBytes / Model.TotalStorageBytes * 100).ToString("F1"))% versions</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-code-branch me-2"></i>
                    Version Statistics
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Avg Versions per Memory</h6>
                            <p class="h4 mb-0">@(Model.TotalMemories > 0 ? ((double)Model.TotalVersions / Model.TotalMemories).ToString("F2") : "0")</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Avg Events per Memory</h6>
                            <p class="h4 mb-0">@(Model.TotalMemories > 0 ? ((double)Model.TotalAuditEvents / Model.TotalMemories).ToString("F2") : "0")</p>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="alert alert-info mb-0" role="alert">
                    <small>
                        <i class="fas fa-info-circle me-1"></i>
                        Use the <a href="/ui/tools" class="alert-link">Version Purge tool</a> to clean up old version snapshots.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- System Information -->
<div class="row mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-cogs me-2"></i>
                    System Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Database Engine</h6>
                            <p class="mb-0">
                                <i class="fas fa-database me-2 text-primary"></i>
                                PostgreSQL with pgvector extension
                            </p>
                        </div>
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Framework</h6>
                            <p class="mb-0">
                                <i class="fab fa-microsoft me-2 text-info"></i>
                                ASP.NET Core 9.0
                            </p>
                        </div>
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Search Technology</h6>
                            <p class="mb-0">
                                <i class="fas fa-search me-2 text-success"></i>
                                Vector Similarity Search
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Embedding Model</h6>
                            <p class="mb-0">
                                <i class="fas fa-brain me-2 text-warning"></i>
                                @(Model.EmbeddingDimensions)-dimensional vectors
                            </p>
                        </div>
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">API Protocol</h6>
                            <p class="mb-0">
                                <i class="fas fa-plug me-2 text-danger"></i>
                                Model Context Protocol (MCP)
                            </p>
                        </div>
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Last Updated</h6>
                            <p class="mb-0">
                                <i class="fas fa-clock me-2 text-muted"></i>
                                @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-tools me-2"></i>
                    Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                                        <a asp-controller="Home" asp-action="Create" class="btn btn-primary">                        <i class="fas fa-plus me-2"></i>                        Add New Memory                    </a>                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">                        <i class="fas fa-list me-2"></i>                        View All Memories                    </a>
                    <button class="btn btn-outline-secondary" onclick="refreshStats()">
                        <i class="fas fa-sync-alt me-2"></i>
                        Refresh Stats
                    </button>
                </div>
            </div>
        </div>
        
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    Health Status
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-success rounded-pill me-2">
                        <i class="fas fa-check"></i>
                    </span>
                    <span>Database Connection</span>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-success rounded-pill me-2">
                        <i class="fas fa-check"></i>
                    </span>
                    <span>Embedding Service</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="badge bg-success rounded-pill me-2">
                        <i class="fas fa-check"></i>
                    </span>
                    <span>Vector Operations</span>
                </div>
                <div class="mt-3">
                    <small class="text-muted">
                        <a href="/healthz" target="_blank" class="text-decoration-none">
                            <i class="fas fa-external-link-alt me-1"></i>
                            View detailed health check
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Performance Metrics (Placeholder for future enhancements) -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-tachometer-alt me-2"></i>
                    Performance Insights
                </h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-3">
                        <div class="border-end pe-3">
                            <h6 class="text-muted">Search Accuracy</h6>
                            <div class="text-success h5">
                                <i class="fas fa-bullseye me-1"></i>
                                Vector-based
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="border-end pe-3">
                            <h6 class="text-muted">Scalability</h6>
                            <div class="text-info h5">
                                <i class="fas fa-expand-arrows-alt me-1"></i>
                                PostgreSQL
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="border-end pe-3">
                            <h6 class="text-muted">Memory Types</h6>
                            <div class="text-warning h5" id="memoryTypes">
                                <i class="fas fa-tags me-1"></i>
                                <span id="typeCount">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <h6 class="text-muted">API Compatibility</h6>
                        <div class="text-primary h5">
                            <i class="fas fa-plug me-1"></i>
                            MCP Standard
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Load additional stats on page load
document.addEventListener('DOMContentLoaded', function() {
    loadMemoryTypes();
});

async function loadMemoryTypes() {
    try {
        const response = await fetch('/api/memory/types');
        const types = await response.json();
        
        document.getElementById('typeCount').textContent = types.length + ' types';
        
    } catch (error) {
        console.error('Error loading memory types:', error);
        document.getElementById('typeCount').textContent = 'N/A';
    }
}

function refreshStats() {
    // Refresh the page to get updated stats
    window.location.reload();
}

// Add some animations to the cards on load
document.addEventListener('DOMContentLoaded', function() {
    const cards = document.querySelectorAll('.card');
    cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
            card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 100);
    });
});
</script>
} 