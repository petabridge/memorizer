@{
    ViewData["Title"] = "MCP Configuration";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">
                        <i class="fas fa-cog me-2"></i>
                        Model Context Protocol (MCP) Configuration
                    </h3>
                    <span class="badge bg-light text-dark">JSON Configuration</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-8">
                            <p class="text-muted mb-4">
                                Use this configuration to connect MCP-compatible clients to your Memorizer server. 
                                Copy the JSON below and add it to your MCP client configuration file.
                            </p>
                            
                            <div class="position-relative">
                                <div class="card bg-light border-0">
                                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                        <span>
                                            <i class="fas fa-code me-2"></i>
                                            mcp.json
                                        </span>
                                        <button id="copyBtn" class="btn btn-sm btn-outline-light copy-btn" onclick="copyToClipboard()">
                                            <i class="fas fa-copy me-1"></i>
                                            Copy
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        <pre id="mcpConfig" class="mb-0"><code class="language-json">{  "mcpServers": {    "memorizer": {      "url": "<span id="serverUrl">http://localhost:5000/sse</span>"    }  }}</code></pre>
                                    </div>
                                </div>
                            </div>

                                                        <div class="alert alert-info mt-4">                                <i class="fas fa-info-circle me-2"></i>                                <strong>Note:</strong> This simplified configuration uses the SSE (Server-Sent Events) endpoint.                                 The URL is automatically configured based on your server settings.                            </div>
                        </div>
                        
                        <div class="col-lg-4">
                            <div class="card border-0 bg-light">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-lightbulb me-2"></i>
                                        Quick Start
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <h6 class="fw-bold">Available Tools:</h6>
                                    <ul class="list-unstyled">
                                        <li><span class="badge bg-success me-2">store</span>Save memories</li>
                                        <li><span class="badge bg-info me-2">search</span>Find similar memories</li>
                                        <li><span class="badge bg-warning me-2">get</span>Retrieve by ID</li>
                                        <li><span class="badge bg-secondary me-2">delete</span>Remove memories</li>
                                    </ul>
                                    
                                    <hr>
                                    
                                    <h6 class="fw-bold">Example Usage:</h6>
                                    <small class="text-muted">
                                        Add this to your AI agent's system prompt:
                                    </small>
                                    <div class="bg-white p-2 rounded mt-2" style="font-size: 0.8em;">
                                        <em>"You have access to long-term memory via the memorizer MCP server. Use the store, search, get, and delete tools to manage knowledge."</em>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <a href="/ui/stats" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-chart-bar me-1"></i>
                                    View Statistics
                                </a>
                                <a href="/ui/" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-list me-1"></i>
                                    Browse Memories
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Load the actual server URL from the API
            fetch(window.location.origin + '/ui/mcp-config-json')
                .then(response => response.json())
                .then(data => {
                    const mcpConfigElement = document.getElementById('mcpConfig');
                    
                    if (mcpConfigElement) {
                        // Update the full JSON config with pretty-printing and syntax highlighting
                        const fullConfig = JSON.stringify(data, null, 2);
                        mcpConfigElement.innerHTML = `<code class="language-json">${escapeHtml(fullConfig)}</code>`;
                        
                        // Re-run Prism syntax highlighting
                        if (window.Prism) {
                            Prism.highlightAll();
                        }
                    }
                })
                .catch(error => {
                    console.error('Error loading MCP config:', error);
                });
        });

        function copyToClipboard() {
            const configElement = document.getElementById('mcpConfig');
            const configText = configElement.textContent;
            
            // Create a temporary textarea element
            const textarea = document.createElement('textarea');
            textarea.value = configText;
            document.body.appendChild(textarea);
            
            // Select and copy the text
            textarea.select();
            document.execCommand('copy');
            
            // Remove the temporary element
            document.body.removeChild(textarea);
            
            // Update button to show success
            const btn = document.getElementById('copyBtn');
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check me-1"></i>Copied!';
            btn.classList.remove('btn-outline-light');
            btn.classList.add('btn-success');
            
            // Reset button after 2 seconds
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-light');
            }, 2000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
} 