@{
    ViewData["Title"] = "View Memory";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-eye me-2"></i>
                        <span id="memoryTitle">View Memory</span>
                    </h4>
                    <div class="btn-group" role="group">
                        <!-- Archive button (shown for non-archived memories) -->
                        <button type="button" class="btn btn-warning" id="archiveBtn" style="display: none;" onclick="promptArchive()">
                            <i class="fas fa-archive me-1"></i>
                            Archive
                        </button>
                        <!-- Restore button (shown for archived memories) -->
                        <button type="button" class="btn btn-success" id="restoreBtn" style="display: none;" onclick="promptRestore()">
                            <i class="fas fa-undo me-1"></i>
                            Restore
                        </button>
                        <a asp-controller="Home" asp-action="Edit" asp-route-id="@ViewBag.MemoryId" class="btn btn-primary" id="editBtn">
                            <i class="fas fa-edit me-1"></i>
                            Edit
                        </a>
                        <button type="button" class="btn btn-danger" onclick="deleteMemory()">
                            <i class="fas fa-trash me-1"></i>
                            Delete
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body" id="viewContent">
                <!-- Loading state -->
                <div class="d-flex justify-content-center py-5" id="loadingSpinner">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading memory...</span>
                    </div>
                </div>

                <!-- Memory content (hidden initially) -->
                <div id="memoryContent" style="display: none;">
                    <!-- Location/Owner context -->
                    <div id="memoryLocationBanner" class="alert alert-info mb-4" style="display: none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-folder-open me-2"></i>
                                <span id="memoryLocationText">Location</span>
                            </div>
                            <a id="memoryLocationLink" href="#" class="btn btn-sm btn-outline-info">
                                <i class="fas fa-arrow-right me-1"></i>View All
                            </a>
                        </div>
                    </div>

                    <!-- Archived Status Banner -->
                    <div id="archivedBanner" class="alert alert-warning mb-4 archived-banner" style="display: none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-archive me-2"></i>
                                <strong>Archived Memory</strong> - This memory is archived and hidden from default searches.
                            </div>
                            <button class="btn btn-sm btn-outline-warning" onclick="promptRestore()">
                                <i class="fas fa-undo me-1"></i>Restore
                            </button>
                        </div>
                    </div>

                    <!-- Memory metadata -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Memory Details
                                    </h6>
                                    <div class="row">
                                        <div class="col-sm-4"><strong>Type:</strong></div>
                                        <div class="col-sm-8"><span id="memoryType" class="badge bg-primary"></span></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Source:</strong></div>
                                        <div class="col-sm-8" id="memorySource"></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Confidence:</strong></div>
                                        <div class="col-sm-8" id="memoryConfidence"></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Created:</strong></div>
                                        <div class="col-sm-8" id="memoryCreated"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        <i class="fas fa-tags me-2"></i>
                                        Tags
                                    </h6>
                                    <div id="memoryTags">
                                        <span class="text-muted">No tags</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Rendered content -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="fas fa-file-alt me-2"></i>
                                Content
                            </h5>
                        </div>
                        <div class="card-body">
                            <div id="renderedContent" class="markdown-content">
                                <!-- Rendered markdown will be inserted here -->
                            </div>
                        </div>
                    </div>

                    <!-- Related memories section -->
                    <div id="relatedMemoriesSection" style="display:none;" class="mt-4">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        <i class="fas fa-link me-2"></i>
                                        Related Memories
                                        <span id="relatedMemoriesCount" class="badge bg-secondary ms-2"></span>
                                    </h5>
                                    <div class="form-check form-switch" id="showArchivedRelationshipsContainer" style="display:none;">
                                        <input class="form-check-input" type="checkbox" id="showArchivedRelationships">
                                        <label class="form-check-label archived-toggle-label" for="showArchivedRelationships">
                                            Show Archived
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="row" id="relatedMemoriesList">
                                    <!-- Related memories will be inserted here -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Similar Memories Discovery section -->
                    <div id="similarMemoriesSection" class="mt-4">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        <i class="fas fa-brain me-2"></i>
                                        Similar Memories
                                    </h5>
                                    <button type="button" class="btn btn-sm btn-light" onclick="toggleSimilarMemoriesSettings()" title="Adjust similarity settings">
                                        <i class="fas fa-sliders-h"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <!-- Settings panel (collapsed by default) -->
                                <div id="similarMemoriesSettings" class="mb-3" style="display:none;">
                                    <div class="card bg-light similar-settings-card">
                                        <div class="card-body py-2">
                                            <div class="row align-items-center g-3">
                                                <div class="col-md-8">
                                                    <label for="similarityThreshold" class="form-label mb-1 small">
                                                        Similarity Threshold: <span id="thresholdValue" class="fw-bold">70%</span>
                                                    </label>
                                                    <input type="range" class="form-range" id="similarityThreshold"
                                                           min="50" max="95" step="5" value="70"
                                                           oninput="updateThresholdDisplay(this.value)">
                                                    <div class="d-flex justify-content-between small text-muted">
                                                        <span>More results</span>
                                                        <span>More similar</span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <button type="button" class="btn btn-primary btn-sm w-100" onclick="loadSimilarMemories()">
                                                        <i class="fas fa-search me-1"></i>
                                                        Search
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Loading state -->
                                <div id="similarMemoriesLoading" class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                        <span class="visually-hidden">Finding similar memories...</span>
                                    </div>
                                    <p class="text-muted small mt-2 mb-0">Searching for similar memories...</p>
                                </div>

                                <!-- Empty state -->
                                <div id="similarMemoriesEmpty" style="display:none;">
                                    <p class="text-muted mb-0">
                                        <i class="fas fa-info-circle me-2"></i>
                                        No similar memories found. Try lowering the similarity threshold.
                                    </p>
                                </div>

                                <!-- Results -->
                                <div id="similarMemoriesContent" style="display:none;">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <small class="text-muted">
                                            Found <span id="similarMemoriesCount">0</span> similar memories
                                        </small>
                                        <button type="button" class="btn btn-success btn-sm" id="createRelationshipsBtn"
                                                onclick="createSelectedRelationships()" style="display:none;">
                                            <i class="fas fa-link me-1"></i>
                                            Link Selected (<span id="selectedCount">0</span>)
                                        </button>
                                    </div>
                                    <div id="similarMemoriesList">
                                        <!-- Similar memories will be inserted here -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Version History section -->
                    <div class="mt-4">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        <i class="fas fa-history me-2"></i>
                                        Version History
                                    </h5>
                                    <span class="badge bg-secondary" id="versionBadge">v1</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div id="versionHistoryLoading" class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                        <span class="visually-hidden">Loading version history...</span>
                                    </div>
                                </div>
                                <div id="versionHistoryContent" style="display:none;">
                                    <div id="versionHistoryEmpty" style="display:none;">
                                        <p class="text-muted mb-0">
                                            <i class="fas fa-info-circle me-2"></i>
                                            This memory has only one version (initial creation).
                                        </p>
                                    </div>
                                    <div id="versionTimeline">
                                        <!-- Version timeline will be inserted here -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Error state (hidden initially) -->
                <div id="errorState" style="display: none;" class="text-center py-5">
                    <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                    <h5 class="text-muted">Memory Not Found</h5>
                    <p class="text-muted">The memory you're trying to view could not be found.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-arrow-left me-2"></i>
                        Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Revert Confirmation Modal - placed outside card to avoid transform issues -->
<div class="modal fade" id="revertModal" tabindex="-1" aria-labelledby="revertModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="revertModalLabel">
                    <i class="fas fa-undo me-2"></i>
                    Confirm Revert
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to revert this memory to <strong>version <span id="revertTargetVersion"></span></strong>?</p>
                <p class="text-muted small">
                    This will restore all content, tags, title, and metadata from that version.
                    A new version will be created recording this revert operation.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="confirmRevertBtn" onclick="confirmRevert()">
                    <i class="fas fa-undo me-1"></i>
                    Revert
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1" aria-labelledby="archiveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="archiveModalLabel">
                    <i class="fas fa-archive me-2"></i>
                    Confirm Archive
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to archive this memory?</p>
                <p class="text-muted small">
                    Archived memories are hidden from default searches and relationship displays.
                    They can be restored at any time.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="confirmArchiveBtn" onclick="confirmArchive()">
                    <i class="fas fa-archive me-1"></i>
                    Archive
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Restore Confirmation Modal -->
<div class="modal fade" id="restoreModal" tabindex="-1" aria-labelledby="restoreModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="restoreModalLabel">
                    <i class="fas fa-undo me-2"></i>
                    Restore Memory
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Restore this memory to active status?</p>
                <div class="mb-3">
                    <label for="restoreArchetype" class="form-label">Restore as:</label>
                    <select id="restoreArchetype" class="form-select">
                        <option value="document">Document (living, editable content)</option>
                        <option value="record">Record (historical, immutable)</option>
                    </select>
                </div>
                <p class="text-muted small">
                    The memory will be visible in searches and relationship displays again.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="confirmRestoreBtn" onclick="confirmRestore()">
                    <i class="fas fa-undo me-1"></i>
                    Restore
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/marked@9.1.6/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script src="~/js/mermaid-integration.js"></script>
<script>
let memoryId = '@(ViewBag.MemoryId?.ToString() ?? "")';
let currentMemoryData = null; // Store the current memory data for version history display
let currentRelationships = []; // Store relationships for filtering

async function deleteMemory() {
    if (!confirm('Are you sure you want to delete this memory? This action cannot be undone.')) {
        return;
    }

    try {
        const response = await fetch(`/api/memory/${memoryId}`, {
            method: 'DELETE'
        });

        if (response.ok) {
            // Redirect to the memories list after successful deletion
            window.location.href = '/memories';
        } else {
            alert('Error deleting memory. Please try again.');
        }
    } catch (error) {
        console.error('Error deleting memory:', error);
        alert('Error deleting memory. Please try again.');
    }
}

// =====================
// Archive/Restore Functions
// =====================

function updateArchiveRestoreUI(memory) {
    const archiveBtn = document.getElementById('archiveBtn');
    const restoreBtn = document.getElementById('restoreBtn');
    const archivedBanner = document.getElementById('archivedBanner');

    const isArchived = memory.archetype === 'archived';

    archiveBtn.style.display = isArchived ? 'none' : 'inline-block';
    restoreBtn.style.display = isArchived ? 'inline-block' : 'none';
    archivedBanner.style.display = isArchived ? 'block' : 'none';
}

function promptArchive() {
    const modalEl = document.getElementById('archiveModal');
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
}

async function confirmArchive() {
    const btn = document.getElementById('confirmArchiveBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Archiving...';
    btn.disabled = true;

    try {
        const response = await fetch(`/api/memory/${memoryId}/archive`, { method: 'PATCH' });
        if (!response.ok) {
            const error = await response.text();
            throw new Error(error || 'Failed to archive');
        }

        bootstrap.Modal.getInstance(document.getElementById('archiveModal')).hide();
        window.location.reload();
    } catch (error) {
        console.error('Error archiving:', error);
        alert('Failed to archive memory: ' + error.message);
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

function promptRestore() {
    const modalEl = document.getElementById('restoreModal');
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
}

async function confirmRestore() {
    const btn = document.getElementById('confirmRestoreBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Restoring...';
    btn.disabled = true;

    const restoreAs = document.getElementById('restoreArchetype').value;

    try {
        const response = await fetch(`/api/memory/${memoryId}/restore`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ restoreAs })
        });
        if (!response.ok) {
            const error = await response.text();
            throw new Error(error || 'Failed to restore');
        }

        bootstrap.Modal.getInstance(document.getElementById('restoreModal')).hide();
        window.location.reload();
    } catch (error) {
        console.error('Error restoring:', error);
        alert('Failed to restore memory: ' + error.message);
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

// Load memory data on page load
document.addEventListener('DOMContentLoaded', function() {
    console.log('Memory ID:', memoryId);
    if (memoryId && memoryId !== '') {
        loadMemory();

        // Fallback: Force hide spinner after 5 seconds
        setTimeout(function() {
            const spinner = document.getElementById('loadingSpinner');
            if (spinner && spinner.style.display !== 'none') {
                console.warn('Spinner still visible after 5 seconds, forcing hide');
                hideSpinner();
            }
        }, 5000);
    } else {
        showError();
    }

    // Add event listener for show archived relationships toggle
    const showArchivedToggle = document.getElementById('showArchivedRelationships');
    if (showArchivedToggle) {
        showArchivedToggle.addEventListener('change', function() {
            renderRelatedMemories();
        });
    }
});

async function loadMemory() {
    try {
        console.log('Loading memory with ID:', memoryId);
        const response = await fetch(`/api/memory/${memoryId}`);

        if (!response.ok) {
            throw new Error('Memory not found');
        }

        const memory = await response.json();
        console.log('Memory loaded:', memory);

        populateMemoryView(memory);
        console.log('Memory view populated');

        hideSpinner();
        showMemoryContent();

    } catch (error) {
        console.error('Error loading memory:', error);
        showError();
    }
}

// Display owner context (workspace/project)
async function displayOwnerContext(owner) {
    const banner = document.getElementById('memoryLocationBanner');
    const textEl = document.getElementById('memoryLocationText');
    const linkEl = document.getElementById('memoryLocationLink');

    if (!owner) {
        banner.style.display = 'none';
        return;
    }

    // Check if unfiled (empty GUID)
    const emptyGuid = '00000000-0000-0000-0000-000000000000';
    if (owner.id === emptyGuid) {
        textEl.innerHTML = '<strong>Unfiled</strong> - not assigned to any workspace or project';
        linkEl.href = '/memories?unfiled=true';
        banner.style.display = 'block';
        return;
    }

    // Fetch workspace tree to find the name
    try {
        const response = await fetch('/api/workspace-tree');
        if (!response.ok) {
            banner.style.display = 'none';
            return;
        }

        const tree = await response.json();
        const ownerType = owner.type?.toLowerCase();

        if (ownerType === 'project') {
            // Search for project in the tree
            const project = findProjectInTree(tree.workspaces, owner.id);
            if (project) {
                textEl.innerHTML = `<strong>Project:</strong> ${escapeHtml(project.name)}`;
                linkEl.href = `/projects/${owner.id}`;
                banner.style.display = 'block';
            }
        } else if (ownerType === 'workspace') {
            // Search for workspace in the tree
            const workspace = findWorkspaceInTree(tree.workspaces, owner.id);
            if (workspace) {
                textEl.innerHTML = `<strong>Workspace:</strong> ${escapeHtml(workspace.name)}`;
                linkEl.href = `/workspaces/${owner.id}`;
                banner.style.display = 'block';
            }
        }
    } catch (error) {
        console.warn('Could not load owner context:', error);
        banner.style.display = 'none';
    }
}

function findWorkspaceInTree(workspaces, id) {
    for (const ws of workspaces) {
        if (ws.id === id) return ws;
        // Check nested workspaces
        if (ws.children && ws.children.length > 0) {
            const found = findWorkspaceInTree(ws.children, id);
            if (found) return found;
        }
    }
    return null;
}

function findProjectInTree(workspaces, id) {
    for (const ws of workspaces) {
        // Check projects in this workspace
        if (ws.projects) {
            for (const proj of ws.projects) {
                if (proj.id === id) return proj;
                // Check nested projects
                if (proj.children && proj.children.length > 0) {
                    const found = findProjectInChildren(proj.children, id);
                    if (found) return found;
                }
            }
        }
        // Check nested workspaces
        if (ws.children && ws.children.length > 0) {
            const found = findProjectInTree(ws.children, id);
            if (found) return found;
        }
    }
    return null;
}

function findProjectInChildren(projects, id) {
    for (const proj of projects) {
        if (proj.id === id) return proj;
        if (proj.children && proj.children.length > 0) {
            const found = findProjectInChildren(proj.children, id);
            if (found) return found;
        }
    }
    return null;
}

function populateMemoryView(memory) {
    try {
        // Store memory data globally for version history display
        currentMemoryData = memory;

        // Set title
        const title = memory.title || 'Untitled Memory';
        document.getElementById('memoryTitle').textContent = title;
        document.title = `${title} - Memorizer`;

        // Show location/owner context
        displayOwnerContext(memory.owner);

        // Update archive/restore UI based on archetype
        updateArchiveRestoreUI(memory);

        // Set metadata
        document.getElementById('memoryType').textContent = memory.type || 'Unknown';
        document.getElementById('memorySource').textContent = memory.source || 'Unknown';
        document.getElementById('memoryConfidence').innerHTML = createConfidenceBadge(memory.confidence || 1.0);
        document.getElementById('memoryCreated').textContent = formatDateTime(memory.createdAt);

        // Set tags (clickable - link to tag filter)
        const tagsContainer = document.getElementById('memoryTags');
        if (memory.tags && memory.tags.length > 0) {
            tagsContainer.innerHTML = createClickableTagBadges(memory.tags);
        } else {
            tagsContainer.innerHTML = '<span class="text-muted">No tags</span>';
        }

        // Render markdown content
        const content = memory.text || 'No content available';
        const renderedHtml = marked.parse(content);
        document.getElementById('renderedContent').innerHTML = renderedHtml;

        // Highlight code blocks with Prism
        if (typeof Prism !== 'undefined') {
            Prism.highlightAll();
        }

        // Render Mermaid diagrams
        if (typeof MermaidIntegration !== 'undefined') {
            MermaidIntegration.render();
        }

        // Handle related memories
        if (memory.relationships && memory.relationships.length > 0) {
            displayRelatedMemories(memory.relationships);
        }

        // Update version badge and track current version globally
        const versionBadge = document.getElementById('versionBadge');
        if (memory.currentVersion) {
            currentVersion = memory.currentVersion;
            if (versionBadge) {
                versionBadge.textContent = `v${memory.currentVersion}`;
            }
        }

        // Load version history
        loadVersionHistory();

        console.log('All memory view fields populated successfully');
    } catch (error) {
        console.error('Error in populateMemoryView:', error);
        throw error;
    }
}

function displayRelatedMemories(relationships) {
    // Store relationships globally for filtering
    currentRelationships = relationships;

    const section = document.getElementById('relatedMemoriesSection');
    const toggleContainer = document.getElementById('showArchivedRelationshipsContainer');
    const countBadge = document.getElementById('relatedMemoriesCount');

    // Check if any relationships are archived
    const hasArchivedRelationships = relationships.some(rel => rel.targetArchived === true);

    // Show toggle only if there are archived relationships
    if (toggleContainer) {
        toggleContainer.style.display = hasArchivedRelationships ? 'block' : 'none';
    }

    // Render based on current toggle state
    renderRelatedMemories();

    section.style.display = 'block';
}

function renderRelatedMemories() {
    const list = document.getElementById('relatedMemoriesList');
    const showArchived = document.getElementById('showArchivedRelationships')?.checked || false;
    const countBadge = document.getElementById('relatedMemoriesCount');

    list.innerHTML = '';

    // Filter relationships based on archived toggle
    const visibleRelationships = currentRelationships.filter(rel =>
        showArchived || rel.targetArchived !== true
    );

    // Update count badge
    if (countBadge) {
        const archivedCount = currentRelationships.filter(rel => rel.targetArchived === true).length;
        if (archivedCount > 0 && !showArchived) {
            countBadge.textContent = `${visibleRelationships.length} (${archivedCount} archived)`;
        } else {
            countBadge.textContent = visibleRelationships.length.toString();
        }
    }

    visibleRelationships.forEach(rel => {
        const title = rel.relatedMemoryTitle || 'Untitled';
        const type = rel.relatedMemoryType || '';
        const relationshipType = rel.relationshipType || 'related';
        const isArchived = rel.targetArchived === true;

        // Get badge color based on relationship type
        const badgeColor = getRelationshipBadgeColor(relationshipType);

        const col = document.createElement('div');
        col.className = 'col-md-6 col-lg-4 mb-3';

        // Add archived styling class if target is archived
        const cardClass = isArchived ? 'card h-100 related-memory-archived' : 'card h-100';
        const titleClass = isArchived ? 'memory-title-archived' : '';

        col.innerHTML = `
            <div class="${cardClass}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0 ${titleClass}">
                            <a href="/view/${rel.toMemoryId}" class="text-decoration-none">
                                <i class="fas fa-link me-1"></i>
                                ${escapeHtml(title)}
                            </a>
                            ${isArchived ? '<span class="badge badge-archived-indicator ms-1">Archived</span>' : ''}
                        </h6>
                        <span class="badge bg-secondary">${escapeHtml(type)}</span>
                    </div>
                    <div class="mb-2">
                        <span class="badge ${badgeColor} fs-6">
                            <i class="fas fa-arrow-right me-1"></i>
                            ${escapeHtml(relationshipType)}
                        </span>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <div class="btn-group w-100" role="group">
                        <a href="/view/${rel.toMemoryId}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-eye me-1"></i>
                            View
                        </a>
                        <a href="/edit/${rel.toMemoryId}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-edit me-1"></i>
                            Edit
                        </a>
                    </div>
                </div>
            </div>
        `;

        list.appendChild(col);
    });

    // Show empty state if no visible relationships
    if (visibleRelationships.length === 0) {
        list.innerHTML = '<div class="col-12"><p class="text-muted">No related memories to display.</p></div>';
    }
}

function getRelationshipBadgeColor(relationshipType) {
    const type = relationshipType.toLowerCase();
    switch (type) {
        case 'explains':
        case 'explanation-of':
            return 'bg-info';
        case 'example-of':
        case 'example':
            return 'bg-success';
        case 'related-to':
        case 'related':
            return 'bg-primary';
        case 'supersedes':
        case 'replaces':
            return 'bg-warning';
        case 'depends-on':
        case 'requires':
            return 'bg-danger';
        case 'chunk-of':
        case 'part-of':
            return 'bg-secondary';
        default:
            return 'bg-dark';
    }
}

function hideSpinner() {
    const spinner = document.getElementById('loadingSpinner');
    if (spinner) {
        spinner.style.display = 'none';
        spinner.style.visibility = 'hidden';
        spinner.classList.add('d-none');
        console.log('Spinner hidden');
    }
}

function showMemoryContent() {
    const content = document.getElementById('memoryContent');
    if (content) {
        content.style.display = 'block';
        console.log('Memory content shown');
    }
}

function showError() {
    hideSpinner();
    document.getElementById('memoryContent').style.display = 'none';
    document.getElementById('errorState').style.display = 'block';
}

// =====================
// Version History Functions
// =====================

let pendingRevertVersion = null;
let versionHistory = [];
let currentVersion = 1; // Track the current version of the memory

async function loadVersionHistory() {
    try {
        const response = await fetch(`/api/memory/${memoryId}/versions`);
        if (!response.ok) {
            console.warn('Could not load version history');
            document.getElementById('versionHistoryLoading').style.display = 'none';
            document.getElementById('versionHistoryContent').style.display = 'block';
            document.getElementById('versionHistoryEmpty').style.display = 'block';
            return;
        }

        versionHistory = await response.json();
        displayVersionHistory(versionHistory);
    } catch (error) {
        console.error('Error loading version history:', error);
        document.getElementById('versionHistoryLoading').style.display = 'none';
        document.getElementById('versionHistoryContent').style.display = 'block';
        document.getElementById('versionHistoryEmpty').style.display = 'block';
    }
}

function displayVersionHistory(versions) {
    const loadingEl = document.getElementById('versionHistoryLoading');
    const contentEl = document.getElementById('versionHistoryContent');
    const emptyEl = document.getElementById('versionHistoryEmpty');
    const timelineEl = document.getElementById('versionTimeline');

    loadingEl.style.display = 'none';
    contentEl.style.display = 'block';

    // Build the complete version list including the current version
    // Version snapshots only contain historical versions (before edits)
    // We need to add the current version at the beginning
    let allVersions = versions ? [...versions] : [];

    // Check if the current version is already in the list
    // (This happens when current version equals the highest snapshot version,
    // e.g., for newly created or migrated memories)
    const hasCurrentInSnapshots = allVersions.some(v => v.versionNumber === currentVersion);

    if (!hasCurrentInSnapshots && currentMemoryData && currentVersion > 0) {
        // Synthesize a current version entry from the live memory data
        // Use updatedAt if available, otherwise fall back to createdAt
        const currentVersionEntry = {
            versionNumber: currentVersion,
            versionedAt: currentMemoryData.updatedAt || currentMemoryData.createdAt,
            events: [], // Current version doesn't have events yet (they describe changes TO reach this version)
            isCurrent: true // Flag to identify this as the live/current version
        };
        allVersions.unshift(currentVersionEntry);
    }

    // Show empty message only if there are truly no versions at all
    if (allVersions.length === 0) {
        emptyEl.style.display = 'block';
        return;
    }

    timelineEl.innerHTML = '';

    allVersions.forEach((version, index) => {
        const hasPrevious = index < allVersions.length - 1;
        const isCurrentVersion = version.versionNumber === currentVersion;

        // Parse events to display what changed - use displayText from strongly-typed events
        let changeDescription = version.isCurrent ? 'Current state' : 'Version snapshot';
        if (version.events && version.events.length > 0) {
            // Use displayText property which contains the rich change description
            changeDescription = version.events.map(e => e.displayText || formatEventType(e.eventType)).join(', ');
        }

        // Build button group - current version only gets compare button (if applicable)
        let buttons = '';
        if (!isCurrentVersion) {
            buttons += `
                <a href="/view/${memoryId}/version/${version.versionNumber}" class="btn btn-outline-info btn-sm" title="View this version">
                    <i class="fas fa-eye"></i>
                </a>`;
        }
        if (hasPrevious) {
            buttons += `
                <a href="/view/${memoryId}/compare/${allVersions[index + 1].versionNumber}/${version.versionNumber}" class="btn btn-outline-primary btn-sm" title="Compare with previous">
                    <i class="fas fa-code-compare"></i>
                </a>`;
        }
        if (!isCurrentVersion) {
            buttons += `
                <button class="btn btn-outline-warning btn-sm" onclick="promptRevert(${version.versionNumber})" title="Revert to this version">
                    <i class="fas fa-undo"></i>
                </button>`;
        }

        const versionItem = document.createElement('div');
        versionItem.className = 'version-item d-flex align-items-start mb-3 pb-3 border-bottom';
        versionItem.innerHTML = `
            <div class="version-marker me-3">
                <span class="badge ${isCurrentVersion ? 'bg-primary' : 'bg-secondary'} rounded-pill">v${version.versionNumber}</span>
            </div>
            <div class="version-content flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>Version ${version.versionNumber}</strong>${isCurrentVersion ? ' <span class="badge bg-success">Current</span>' : ''}
                        <br>
                        <small class="text-muted">
                            <i class="fas fa-clock me-1"></i>
                            ${formatDateTime(version.versionedAt)}
                        </small>
                        <br>
                        <small class="text-info">
                            <i class="fas fa-pen me-1"></i>
                            ${escapeHtml(changeDescription)}
                        </small>
                    </div>
                    <div class="btn-group btn-group-sm">
                        ${buttons}
                    </div>
                </div>
            </div>
        `;
        timelineEl.appendChild(versionItem);
    });
}

function formatEventType(eventType) {
    const mappings = {
        // New strongly-typed event types
        'memory_created': 'Memory created',
        'content_updated': 'Content updated',
        'metadata_updated': 'Metadata updated',
        'relationship_added': 'Relationship added',
        'relationship_removed': 'Relationship removed',
        'memory_reverted': 'Reverted',
        // Legacy event types (for backwards compatibility)
        'text_changed': 'Content updated',
        'title_changed': 'Title changed',
        'tags_changed': 'Tags modified',
        'type_changed': 'Type changed',
        'confidence_changed': 'Confidence updated',
        'source_changed': 'Source changed',
        'created': 'Created',
        'reverted': 'Reverted',
        'update': 'Updated'
    };
    return mappings[eventType] || eventType;
}

function promptRevert(versionNumber) {
    pendingRevertVersion = versionNumber;
    document.getElementById('revertTargetVersion').textContent = versionNumber;
    const modalEl = document.getElementById('revertModal');
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
}

async function confirmRevert() {
    if (!pendingRevertVersion) return;

    const btn = document.getElementById('confirmRevertBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Reverting...';
    btn.disabled = true;

    try {
        const response = await fetch(`/api/memory/${memoryId}/versions/${pendingRevertVersion}/revert`, {
            method: 'POST'
        });

        if (!response.ok) {
            throw new Error('Failed to revert');
        }

        // Close modal and reload page
        bootstrap.Modal.getInstance(document.getElementById('revertModal')).hide();
        window.location.reload();
    } catch (error) {
        console.error('Error reverting:', error);
        alert('Failed to revert to version. Please try again.');
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

// =====================
// Similar Memories Functions
// =====================

let similaritySettings = {
    defaultThreshold: 0.7,
    minThreshold: 0.5,
    maxThreshold: 0.95,
    defaultLimit: 10
};
let selectedSimilarMemories = new Map(); // Map of id -> {score, title}

// Load similarity settings from server
async function loadSimilaritySettings() {
    try {
        const response = await fetch('/api/memory/similarity/settings');
        if (response.ok) {
            similaritySettings = await response.json();
            // Update slider bounds and default value
            const slider = document.getElementById('similarityThreshold');
            slider.min = Math.round(similaritySettings.minThreshold * 100);
            slider.max = Math.round(similaritySettings.maxThreshold * 100);
            slider.value = Math.round(similaritySettings.defaultThreshold * 100);
            updateThresholdDisplay(slider.value);
        }
    } catch (error) {
        console.warn('Could not load similarity settings, using defaults:', error);
    }
}

function toggleSimilarMemoriesSettings() {
    const settings = document.getElementById('similarMemoriesSettings');
    settings.style.display = settings.style.display === 'none' ? 'block' : 'none';
}

function updateThresholdDisplay(value) {
    document.getElementById('thresholdValue').textContent = value + '%';
}

async function loadSimilarMemories() {
    const loadingEl = document.getElementById('similarMemoriesLoading');
    const emptyEl = document.getElementById('similarMemoriesEmpty');
    const contentEl = document.getElementById('similarMemoriesContent');
    const listEl = document.getElementById('similarMemoriesList');

    // Show loading state
    loadingEl.style.display = 'block';
    emptyEl.style.display = 'none';
    contentEl.style.display = 'none';

    try {
        const threshold = document.getElementById('similarityThreshold').value / 100;
        const response = await fetch(`/api/memory/${memoryId}/similar?threshold=${threshold}&limit=${similaritySettings.defaultLimit}`);

        if (!response.ok) {
            throw new Error('Failed to load similar memories');
        }

        const data = await response.json();
        loadingEl.style.display = 'none';

        if (!data.similarMemories || data.similarMemories.length === 0) {
            emptyEl.style.display = 'block';
            return;
        }

        // Clear previous selection
        selectedSimilarMemories.clear();
        updateSelectionUI();

        // Display results
        document.getElementById('similarMemoriesCount').textContent = data.similarMemories.length;
        listEl.innerHTML = '';

        data.similarMemories.forEach(mem => {
            const similarityPercent = (mem.similarity * 100).toFixed(1);
            const hasRelationship = mem.hasExistingRelationship;

            const item = document.createElement('div');
            item.className = 'similar-memory-item d-flex align-items-start p-3 border-bottom';
            item.innerHTML = `
                <div class="form-check me-3" style="min-width: 25px;">
                    ${!hasRelationship ? `
                    <input class="form-check-input similar-memory-checkbox" type="checkbox"
                           id="similar-${mem.id}" data-id="${mem.id}" data-score="${mem.similarity}" data-title="${escapeHtml(mem.title)}"
                           onchange="toggleSimilarMemorySelection('${mem.id}', ${mem.similarity}, '${escapeHtml(mem.title).replace(/'/g, "\\'")}')">
                    ` : ''}
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">
                                <a href="/view/${mem.id}" class="text-decoration-none">
                                    ${escapeHtml(mem.title || 'Untitled')}
                                </a>
                            </h6>
                            <span class="badge bg-secondary me-2">${escapeHtml(mem.type)}</span>
                            ${hasRelationship ?
                                '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Already linked</span>' :
                                ''}
                        </div>
                        <div class="text-end">
                            <div class="similarity-score ${getSimilarityClass(mem.similarity)}">
                                ${similarityPercent}%
                            </div>
                            <small class="text-muted">similarity</small>
                        </div>
                    </div>
                </div>
            `;
            listEl.appendChild(item);
        });

        contentEl.style.display = 'block';
    } catch (error) {
        console.error('Error loading similar memories:', error);
        loadingEl.style.display = 'none';
        emptyEl.innerHTML = '<p class="text-danger mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Error loading similar memories. Please try again.</p>';
        emptyEl.style.display = 'block';
    }
}

function getSimilarityClass(similarity) {
    if (similarity >= 0.9) return 'similarity-very-high';
    if (similarity >= 0.8) return 'similarity-high';
    if (similarity >= 0.7) return 'similarity-medium';
    return 'similarity-low';
}

function toggleSimilarMemorySelection(id, score, title) {
    if (selectedSimilarMemories.has(id)) {
        selectedSimilarMemories.delete(id);
    } else {
        selectedSimilarMemories.set(id, { score, title });
    }
    updateSelectionUI();
}

function updateSelectionUI() {
    const count = selectedSimilarMemories.size;
    const btn = document.getElementById('createRelationshipsBtn');
    const countSpan = document.getElementById('selectedCount');

    countSpan.textContent = count;
    btn.style.display = count > 0 ? 'inline-block' : 'none';
}

async function createSelectedRelationships() {
    if (selectedSimilarMemories.size === 0) return;

    const btn = document.getElementById('createRelationshipsBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Linking...';
    btn.disabled = true;

    try {
        const relationships = Array.from(selectedSimilarMemories.entries()).map(([id, data]) => ({
            targetMemoryId: id,
            score: data.score
        }));

        const response = await fetch(`/api/memory/${memoryId}/similar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ relationships })
        });

        if (!response.ok) {
            throw new Error('Failed to create relationships');
        }

        const result = await response.json();

        // Show success message
        const count = result.relationshipsCreated / 2; // Divide by 2 since bidirectional
        alert(`Successfully linked ${count} similar ${count === 1 ? 'memory' : 'memories'}.`);

        // Reload the page to show updated relationships
        window.location.reload();
    } catch (error) {
        console.error('Error creating relationships:', error);
        alert('Failed to create relationships. Please try again.');
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

// Initialize similar memories on page load
document.addEventListener('DOMContentLoaded', function() {
    // Load similarity settings then load similar memories
    loadSimilaritySettings().then(() => {
        // Small delay to let the memory load first
        setTimeout(() => loadSimilarMemories(), 500);
    });
});
</script>
}
