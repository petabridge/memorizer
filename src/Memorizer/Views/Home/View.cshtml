@{
    ViewData["Title"] = "View Memory";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-eye me-2"></i>
                        <span id="memoryTitle">View Memory</span>
                    </h4>
                    <div class="btn-group" role="group">
                        <a asp-controller="Home" asp-action="Edit" asp-route-id="@ViewBag.MemoryId" class="btn btn-primary">
                            <i class="fas fa-edit me-1"></i>
                            Edit
                        </a>
                        <button type="button" class="btn btn-danger" onclick="deleteMemory()">
                            <i class="fas fa-trash me-1"></i>
                            Delete
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body" id="viewContent">
                <!-- Loading state -->
                <div class="d-flex justify-content-center py-5" id="loadingSpinner">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading memory...</span>
                    </div>
                </div>

                <!-- Memory content (hidden initially) -->
                <div id="memoryContent" style="display: none;">
                    <!-- Memory metadata -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Memory Details
                                    </h6>
                                    <div class="row">
                                        <div class="col-sm-4"><strong>Type:</strong></div>
                                        <div class="col-sm-8"><span id="memoryType" class="badge bg-primary"></span></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Source:</strong></div>
                                        <div class="col-sm-8" id="memorySource"></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Confidence:</strong></div>
                                        <div class="col-sm-8" id="memoryConfidence"></div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-sm-4"><strong>Created:</strong></div>
                                        <div class="col-sm-8" id="memoryCreated"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        <i class="fas fa-tags me-2"></i>
                                        Tags
                                    </h6>
                                    <div id="memoryTags">
                                        <span class="text-muted">No tags</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Rendered content -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="fas fa-file-alt me-2"></i>
                                Content
                            </h5>
                        </div>
                        <div class="card-body">
                            <div id="renderedContent" class="markdown-content">
                                <!-- Rendered markdown will be inserted here -->
                            </div>
                        </div>
                    </div>

                    <!-- Related memories section -->
                    <div id="relatedMemoriesSection" style="display:none;" class="mt-4">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-link me-2"></i>
                                    Related Memories
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="row" id="relatedMemoriesList">
                                    <!-- Related memories will be inserted here -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Version History section -->
                    <div class="mt-4">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        <i class="fas fa-history me-2"></i>
                                        Version History
                                    </h5>
                                    <span class="badge bg-secondary" id="versionBadge">v1</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div id="versionHistoryLoading" class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                        <span class="visually-hidden">Loading version history...</span>
                                    </div>
                                </div>
                                <div id="versionHistoryContent" style="display:none;">
                                    <div id="versionHistoryEmpty" style="display:none;">
                                        <p class="text-muted mb-0">
                                            <i class="fas fa-info-circle me-2"></i>
                                            This memory has only one version (initial creation).
                                        </p>
                                    </div>
                                    <div id="versionTimeline">
                                        <!-- Version timeline will be inserted here -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Revert Confirmation Modal (no fade animation to prevent flickering) -->
                    <div class="modal" id="revertModal" tabindex="-1" aria-labelledby="revertModalLabel" aria-hidden="true" data-bs-backdrop="static">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header bg-warning">
                                    <h5 class="modal-title" id="revertModalLabel">
                                        <i class="fas fa-undo me-2"></i>
                                        Confirm Revert
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Are you sure you want to revert this memory to <strong>version <span id="revertTargetVersion"></span></strong>?</p>
                                    <p class="text-muted small">
                                        This will restore all content, tags, title, and metadata from that version.
                                        A new version will be created recording this revert operation.
                                    </p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-warning" id="confirmRevertBtn" onclick="confirmRevert()">
                                        <i class="fas fa-undo me-1"></i>
                                        Revert
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Error state (hidden initially) -->
                <div id="errorState" style="display: none;" class="text-center py-5">
                    <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                    <h5 class="text-muted">Memory Not Found</h5>
                    <p class="text-muted">The memory you're trying to view could not be found.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-arrow-left me-2"></i>
                        Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/marked@9.1.6/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script src="~/js/mermaid-integration.js"></script>
<script>
let memoryId = '@(ViewBag.MemoryId?.ToString() ?? "")';

async function deleteMemory() {
    if (!confirm('Are you sure you want to delete this memory? This action cannot be undone.')) {
        return;
    }

    try {
        const response = await fetch(`/api/memory/${memoryId}`, {
            method: 'DELETE'
        });

        if (response.ok) {
            // Redirect to the index page after successful deletion
            window.location.href = '/ui/';
        } else {
            alert('Error deleting memory. Please try again.');
        }
    } catch (error) {
        console.error('Error deleting memory:', error);
        alert('Error deleting memory. Please try again.');
    }
}

// Load memory data on page load
document.addEventListener('DOMContentLoaded', function() {
    console.log('Memory ID:', memoryId);
    if (memoryId && memoryId !== '') {
        loadMemory();

        // Fallback: Force hide spinner after 5 seconds
        setTimeout(function() {
            const spinner = document.getElementById('loadingSpinner');
            if (spinner && spinner.style.display !== 'none') {
                console.warn('Spinner still visible after 5 seconds, forcing hide');
                hideSpinner();
            }
        }, 5000);
    } else {
        showError();
    }
});

async function loadMemory() {
    try {
        console.log('Loading memory with ID:', memoryId);
        const response = await fetch(`/api/memory/${memoryId}`);

        if (!response.ok) {
            throw new Error('Memory not found');
        }

        const memory = await response.json();
        console.log('Memory loaded:', memory);

        populateMemoryView(memory);
        console.log('Memory view populated');

        hideSpinner();
        showMemoryContent();

    } catch (error) {
        console.error('Error loading memory:', error);
        showError();
    }
}

function populateMemoryView(memory) {
    try {
        // Set title
        const title = memory.title || 'Untitled Memory';
        document.getElementById('memoryTitle').textContent = title;
        document.title = `${title} - Memorizer`;

        // Set metadata
        document.getElementById('memoryType').textContent = memory.type || 'Unknown';
        document.getElementById('memorySource').textContent = memory.source || 'Unknown';
        document.getElementById('memoryConfidence').innerHTML = createConfidenceBadge(memory.confidence || 1.0);
        document.getElementById('memoryCreated').textContent = formatDateTime(memory.createdAt);

        // Set tags
        const tagsContainer = document.getElementById('memoryTags');
        if (memory.tags && memory.tags.length > 0) {
            tagsContainer.innerHTML = createTagBadges(memory.tags);
        } else {
            tagsContainer.innerHTML = '<span class="text-muted">No tags</span>';
        }

        // Render markdown content
        const content = memory.text || 'No content available';
        const renderedHtml = marked.parse(content);
        document.getElementById('renderedContent').innerHTML = renderedHtml;

        // Highlight code blocks with Prism
        if (typeof Prism !== 'undefined') {
            Prism.highlightAll();
        }

        // Render Mermaid diagrams
        if (typeof MermaidIntegration !== 'undefined') {
            MermaidIntegration.render();
        }

        // Handle related memories
        if (memory.relationships && memory.relationships.length > 0) {
            displayRelatedMemories(memory.relationships);
        }

        // Update version badge
        const versionBadge = document.getElementById('versionBadge');
        if (versionBadge && memory.currentVersion) {
            versionBadge.textContent = `v${memory.currentVersion}`;
        }

        // Load version history
        loadVersionHistory();

        console.log('All memory view fields populated successfully');
    } catch (error) {
        console.error('Error in populateMemoryView:', error);
        throw error;
    }
}

function displayRelatedMemories(relationships) {
    const section = document.getElementById('relatedMemoriesSection');
    const list = document.getElementById('relatedMemoriesList');

    list.innerHTML = '';

    relationships.forEach(rel => {
        const title = rel.relatedMemoryTitle || 'Untitled';
        const type = rel.relatedMemoryType || '';
        const relationshipType = rel.relationshipType || 'related';

        // Get badge color based on relationship type
        const badgeColor = getRelationshipBadgeColor(relationshipType);

        const col = document.createElement('div');
        col.className = 'col-md-6 col-lg-4 mb-3';

        col.innerHTML = `
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0">
                            <a href="/ui/view/${rel.toMemoryId}" class="text-decoration-none">
                                <i class="fas fa-link me-1"></i>
                                ${escapeHtml(title)}
                            </a>
                        </h6>
                        <span class="badge bg-secondary">${escapeHtml(type)}</span>
                    </div>
                    <div class="mb-2">
                        <span class="badge ${badgeColor} fs-6">
                            <i class="fas fa-arrow-right me-1"></i>
                            ${escapeHtml(relationshipType)}
                        </span>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <div class="btn-group w-100" role="group">
                        <a href="/ui/view/${rel.toMemoryId}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-eye me-1"></i>
                            View
                        </a>
                        <a href="/ui/edit/${rel.toMemoryId}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-edit me-1"></i>
                            Edit
                        </a>
                    </div>
                </div>
            </div>
        `;

        list.appendChild(col);
    });

    section.style.display = 'block';
}

function getRelationshipBadgeColor(relationshipType) {
    const type = relationshipType.toLowerCase();
    switch (type) {
        case 'explains':
        case 'explanation-of':
            return 'bg-info';
        case 'example-of':
        case 'example':
            return 'bg-success';
        case 'related-to':
        case 'related':
            return 'bg-primary';
        case 'supersedes':
        case 'replaces':
            return 'bg-warning';
        case 'depends-on':
        case 'requires':
            return 'bg-danger';
        case 'chunk-of':
        case 'part-of':
            return 'bg-secondary';
        default:
            return 'bg-dark';
    }
}

function hideSpinner() {
    const spinner = document.getElementById('loadingSpinner');
    if (spinner) {
        spinner.style.display = 'none';
        spinner.style.visibility = 'hidden';
        spinner.classList.add('d-none');
        console.log('Spinner hidden');
    }
}

function showMemoryContent() {
    const content = document.getElementById('memoryContent');
    if (content) {
        content.style.display = 'block';
        console.log('Memory content shown');
    }
}

function showError() {
    hideSpinner();
    document.getElementById('memoryContent').style.display = 'none';
    document.getElementById('errorState').style.display = 'block';
}

// =====================
// Version History Functions
// =====================

let pendingRevertVersion = null;
let versionHistory = [];

async function loadVersionHistory() {
    try {
        const response = await fetch(`/api/memory/${memoryId}/versions`);
        if (!response.ok) {
            console.warn('Could not load version history');
            document.getElementById('versionHistoryLoading').style.display = 'none';
            document.getElementById('versionHistoryContent').style.display = 'block';
            document.getElementById('versionHistoryEmpty').style.display = 'block';
            return;
        }

        versionHistory = await response.json();
        displayVersionHistory(versionHistory);
    } catch (error) {
        console.error('Error loading version history:', error);
        document.getElementById('versionHistoryLoading').style.display = 'none';
        document.getElementById('versionHistoryContent').style.display = 'block';
        document.getElementById('versionHistoryEmpty').style.display = 'block';
    }
}

function displayVersionHistory(versions) {
    const loadingEl = document.getElementById('versionHistoryLoading');
    const contentEl = document.getElementById('versionHistoryContent');
    const emptyEl = document.getElementById('versionHistoryEmpty');
    const timelineEl = document.getElementById('versionTimeline');

    loadingEl.style.display = 'none';
    contentEl.style.display = 'block';

    // Show empty message only if there are truly no version snapshots
    // (versions.length === 0 means no edits have been made yet)
    if (!versions || versions.length === 0) {
        emptyEl.style.display = 'block';
        return;
    }

    timelineEl.innerHTML = '';

    versions.forEach((version, index) => {
        const isLatest = index === 0;
        const hasPrevious = index < versions.length - 1;

        // Parse events to display what changed - use displayText from strongly-typed events
        let changeDescription = 'Version snapshot';
        if (version.events && version.events.length > 0) {
            // Use displayText property which contains the rich change description
            changeDescription = version.events.map(e => e.displayText || formatEventType(e.eventType)).join(', ');
        }

        // Version snapshots are historical - they represent the state BEFORE an edit
        // The most recent snapshot (index 0) shows what was changed to become the current version
        const versionItem = document.createElement('div');
        versionItem.className = 'version-item d-flex align-items-start mb-3 pb-3 border-bottom';
        versionItem.innerHTML = `
            <div class="version-marker me-3">
                <span class="badge bg-secondary rounded-pill">v${version.versionNumber}</span>
            </div>
            <div class="version-content flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>Version ${version.versionNumber}</strong>
                        <br>
                        <small class="text-muted">
                            <i class="fas fa-clock me-1"></i>
                            ${formatDateTime(version.versionedAt)}
                        </small>
                        <br>
                        <small class="text-info">
                            <i class="fas fa-pen me-1"></i>
                            ${escapeHtml(changeDescription)}
                        </small>
                    </div>
                    <div class="btn-group btn-group-sm">
                        <a href="/ui/view/${memoryId}/version/${version.versionNumber}" class="btn btn-outline-info btn-sm" title="View this version">
                            <i class="fas fa-eye"></i>
                        </a>
                        ${hasPrevious ? `
                        <a href="/ui/view/${memoryId}/compare/${versions[index + 1].versionNumber}/${version.versionNumber}" class="btn btn-outline-primary btn-sm" title="Compare with previous">
                            <i class="fas fa-code-compare"></i>
                        </a>
                        ` : ''}
                        <button class="btn btn-outline-warning btn-sm" onclick="promptRevert(${version.versionNumber})" title="Revert to this version">
                            <i class="fas fa-undo"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
        timelineEl.appendChild(versionItem);
    });
}

function formatEventType(eventType) {
    const mappings = {
        // New strongly-typed event types
        'memory_created': 'Memory created',
        'content_updated': 'Content updated',
        'metadata_updated': 'Metadata updated',
        'relationship_added': 'Relationship added',
        'relationship_removed': 'Relationship removed',
        'memory_reverted': 'Reverted',
        // Legacy event types (for backwards compatibility)
        'text_changed': 'Content updated',
        'title_changed': 'Title changed',
        'tags_changed': 'Tags modified',
        'type_changed': 'Type changed',
        'confidence_changed': 'Confidence updated',
        'source_changed': 'Source changed',
        'created': 'Created',
        'reverted': 'Reverted',
        'update': 'Updated'
    };
    return mappings[eventType] || eventType;
}

function promptRevert(versionNumber) {
    pendingRevertVersion = versionNumber;
    document.getElementById('revertTargetVersion').textContent = versionNumber;
    const modalEl = document.getElementById('revertModal');
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
}

async function confirmRevert() {
    if (!pendingRevertVersion) return;

    const btn = document.getElementById('confirmRevertBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Reverting...';
    btn.disabled = true;

    try {
        const response = await fetch(`/api/memory/${memoryId}/versions/${pendingRevertVersion}/revert`, {
            method: 'POST'
        });

        if (!response.ok) {
            throw new Error('Failed to revert');
        }

        // Close modal and reload page
        bootstrap.Modal.getInstance(document.getElementById('revertModal')).hide();
        window.location.reload();
    } catch (error) {
        console.error('Error reverting:', error);
        alert('Failed to revert to version. Please try again.');
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}
</script>
}
