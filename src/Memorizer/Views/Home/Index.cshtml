@{
    ViewData["Title"] = "Memory Manager";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="fas fa-brain me-2 text-primary"></i>
            Memory Manager
        </h1>
        <p class="text-muted mb-0">Manage your AI agent memories with vector search capabilities</p>
    </div>
    <div>        <a asp-controller="Home" asp-action="Create" class="btn btn-primary">            <i class="fas fa-plus me-2"></i>            Add Memory        </a>    </div>
</div>

<!-- Vector Search Bar - Moved to top -->
<div class="card mb-4">
    <div class="card-body">
        <form id="vectorSearchForm" class="row g-2 align-items-center" onsubmit="return runVectorSearch(event)">
            <div class="col-md-8">
                <input type="text" id="vectorSearchQuery" class="form-control" placeholder="Vector search memories..." autocomplete="off">
            </div>
            <div class="col-md-2">
                <input type="number" id="vectorSearchMinSim" class="form-control" placeholder="Min similarity (0-1)" min="0" max="1" step="0.01" value="0.7">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">
                    <i class="fas fa-search me-1"></i> Vector Search
                </button>
            </div>
        </form>
    </div>
</div>
<div id="vectorSearchResults"></div>

<!-- Page Size Selector -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="d-flex align-items-center">
                    <label for="pageSize" class="form-label me-3 mb-0">Items per page:</label>
                    <select id="pageSize" class="form-select" style="width: auto;" onchange="changePageSize()">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="text-end">
                    <span class="text-muted" id="memoryCount">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Memory List -->
<div id="memoryList">
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
</div>

<!-- Pagination -->
<div id="pagination" class="d-flex justify-content-center mt-4">
    <!-- Pagination will be inserted here by JavaScript -->
</div>

@section Scripts {
<script>
let currentPage = 1;
let currentPageSize = 20;
let totalPages = 1;
let isVectorSearch = false;

// Load memories on page load
document.addEventListener('DOMContentLoaded', function() {
    loadMemories();
});

function changePageSize() {
    currentPageSize = parseInt(document.getElementById('pageSize').value);
    currentPage = 1; // Reset to first page
    loadMemories();
}

function changePage(page) {
    if (page >= 1 && page <= totalPages) {
        currentPage = page;
        loadMemories();
    }
}

async function loadMemories() {
    try {
        const response = await fetch(`/api/memory?page=${currentPage}&pageSize=${currentPageSize}`);
        const data = await response.json();
        
        displayMemories(data.memories);
        updatePagination(data);
        updateMemoryCount(data);
    } catch (error) {
        console.error('Error loading memories:', error);
        document.getElementById('memoryList').innerHTML = `
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Error loading memories. Please try again.
            </div>
        `;
    }
}

function displayMemories(memories) {
    const listElement = document.getElementById('memoryList');
    
    if (memories.length === 0) {
        listElement.innerHTML = `
            <div class="text-center py-5">
                <i class="fas fa-brain fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No memories found</h5>
                <p class="text-muted">Start by creating your first memory.</p>
                <a href="/ui/create" class="btn btn-primary">                    <i class="fas fa-plus me-2"></i>                    Create Memory                </a>
            </div>
        `;
        return;
    }
    
    let html = '<div class="row">';
    
    memories.forEach(memory => {
        const tags = createTagBadges(memory.tags);
        const title = memory.title || 'Untitled Memory';
        const preview = truncateText(memory.text, 100) || 'No content';
        
        html += `
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card memory-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title mb-0">${escapeHtml(title)}</h6>
                            <span class="badge bg-primary">${escapeHtml(memory.type)}</span>
                        </div>
                        
                        <p class="card-text text-muted small mb-2">${escapeHtml(preview)}</p>
                        
                        <div class="mb-3">
                            ${tags}
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                <i class="fas fa-user me-1"></i>
                                ${escapeHtml(memory.source)}
                            </small>
                            <small class="text-muted">
                                <i class="fas fa-chart-line me-1"></i>
                                ${createConfidenceBadge(memory.confidence)}
                            </small>
                        </div>
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="fas fa-clock me-1"></i>
                                ${formatDate(memory.createdAt)}
                            </small>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="btn-group w-100" role="group">
                            <a href="/ui/view/${memory.id}" class="btn btn-outline-success btn-sm">
                                <i class="fas fa-eye me-1"></i>
                                View
                            </a>
                            <a href="/ui/edit/${memory.id}" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-edit me-1"></i>
                                Edit
                            </a>
                            <button class="btn btn-outline-danger btn-sm" onclick="deleteMemory('${memory.id}')">
                                <i class="fas fa-trash me-1"></i>
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;
    });
    
    html += '</div>';
    listElement.innerHTML = html;
}

function updatePagination(data) {
    totalPages = data.totalPages;
    const paginationElement = document.getElementById('pagination');
    
    if (totalPages <= 1) {
        paginationElement.innerHTML = '';
        return;
    }
    
    let html = '<nav><ul class="pagination">';
    
    // Previous button
    html += `
        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">
                <i class="fas fa-chevron-left"></i>
            </a>
        </li>
    `;
    
    // Page numbers
    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);
    
    if (startPage > 1) {
        html += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(1)">1</a></li>`;
        if (startPage > 2) {
            html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        html += `
            <li class="page-item ${i === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
            </li>
        `;
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
        }
        html += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${totalPages})">${totalPages}</a></li>`;
    }
    
    // Next button
    html += `
        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">
                <i class="fas fa-chevron-right"></i>
            </a>
        </li>
    `;
    
    html += '</ul></nav>';
    paginationElement.innerHTML = html;
}

function updateMemoryCount(data) {
    const start = (data.page - 1) * data.pageSize + 1;
    const end = Math.min(data.page * data.pageSize, data.totalCount);
    
    document.getElementById('memoryCount').textContent = 
        `Showing ${start}-${end} of ${data.totalCount} memories`;
}

async function deleteMemory(id) {
    if (!confirm('Are you sure you want to delete this memory? This action cannot be undone.')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/memory/${id}`, {
            method: 'DELETE'
        });
        
        if (response.ok) {
            loadMemories(); // Reload the list
        } else {
            alert('Error deleting memory. Please try again.');
        }
    } catch (error) {
        console.error('Error deleting memory:', error);
        alert('Error deleting memory. Please try again.');
    }
}

async function runVectorSearch(event) {
    event.preventDefault();
    const query = document.getElementById('vectorSearchQuery').value.trim();
    const minSim = parseFloat(document.getElementById('vectorSearchMinSim').value) || 0.7;
    if (!query) {
        // If search bar is cleared, revert to default list
        isVectorSearch = false;
        document.getElementById('vectorSearchResults').innerHTML = '';
        loadMemories();
        return false;
    }
    isVectorSearch = true;
    document.getElementById('vectorSearchResults').innerHTML = `<div class='d-flex justify-content-center py-5'><div class='spinner-border text-success' role='status'><span class='visually-hidden'>Searching...</span></div></div>`;
    try {
        const response = await fetch(`/api/memory/search?query=${encodeURIComponent(query)}&minSimilarity=${minSim}&limit=20`);
        const results = await response.json();
        displayVectorSearchResults(results);
    } catch (error) {
        document.getElementById('vectorSearchResults').innerHTML = `<div class='alert alert-danger'><i class='fas fa-exclamation-triangle me-2'></i>Error running vector search. Please try again.</div>`;
    }
    return false;
}

function displayVectorSearchResults(results) {
    if (!results || results.length === 0) {
        document.getElementById('vectorSearchResults').innerHTML = `<div class='alert alert-info'><i class='fas fa-info-circle me-2'></i>No vector search results found.</div>`;
        return;
    }
    let html = `<div class='card mb-4'><div class='card-body'><h5 class='mb-3'><i class='fas fa-search me-2 text-success'></i>Vector Search Results</h5><div class='row'>`;
    results.forEach(memory => {
        const tags = createTagBadges(memory.tags);
        const title = memory.title || 'Untitled Memory';
        const preview = truncateText(memory.text, 100) || 'No content';
        const similarity = memory.similarity !== null && memory.similarity !== undefined ? (100 * (1 - memory.similarity)).toFixed(1) : 'N/A';
        // Related memories HTML
        let relatedHtml = '';
        if (memory.relationships && memory.relationships.length > 0) {
            relatedHtml = `<div class='mt-2'><strong>Related:</strong><div class='mt-1'>`;
            memory.relationships.forEach(rel => {
                const relTitle = rel.relatedMemoryTitle || 'Untitled';
                const relType = rel.relatedMemoryType || '';
                const relationshipType = rel.relationshipType || 'related';
                const badgeColor = getRelationshipBadgeColor(relationshipType);
                relatedHtml += `
                    <div class='mb-1'>
                        <span class='badge ${badgeColor} me-1'>
                            <i class='fas fa-arrow-right me-1'></i>
                            ${escapeHtml(relationshipType)}
                        </span>
                        <a href='/ui/view/${rel.toMemoryId}' class='text-decoration-none'>
                            <i class='fas fa-link me-1'></i>${escapeHtml(relTitle)}
                        </a>
                        <span class='badge bg-light text-dark ms-1'>${escapeHtml(relType)}</span>
                    </div>
                `;
            });
            relatedHtml += `</div></div>`;
        }
        html += `
            <div class='col-md-6 col-lg-4 mb-4'>
                <div class='card memory-card h-100 border-success'>
                    <div class='card-body'>
                        <div class='d-flex justify-content-between align-items-start mb-2'>
                            <h6 class='card-title mb-0'>${escapeHtml(title)}</h6>
                            <span class='badge bg-primary'>${escapeHtml(memory.type)}</span>
                        </div>
                        <p class='card-text text-muted small mb-2'>${escapeHtml(preview)}</p>
                        <div class='mb-3'>${tags}</div>
                        <div class='d-flex justify-content-between align-items-center'>
                            <small class='text-muted'><i class='fas fa-user me-1'></i>${escapeHtml(memory.source)}</small>
                            <small class='text-muted'><i class='fas fa-chart-line me-1'></i>${createConfidenceBadge(memory.confidence)}</small>
                        </div>
                        <div class='mt-3'>
                            <small class='text-muted'><i class='fas fa-clock me-1'></i>${formatDate(memory.createdAt)}</small>
                        </div>
                        <div class='mt-2'>
                            <span class='badge bg-success'>Similarity: ${similarity}%</span>
                        </div>
                        ${relatedHtml}
                    </div>
                    <div class='card-footer bg-transparent'>
                        <div class='btn-group w-100' role='group'>
                            <a href='/ui/view/${memory.id}' class='btn btn-outline-success btn-sm'><i class='fas fa-eye me-1'></i>View</a>
                            <a href='/ui/edit/${memory.id}' class='btn btn-outline-primary btn-sm'><i class='fas fa-edit me-1'></i>Edit</a>
                            <button class='btn btn-outline-danger btn-sm' onclick='deleteMemory("${memory.id}")'><i class='fas fa-trash me-1'></i>Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        `;
    });
    html += '</div></div></div>';
    document.getElementById('vectorSearchResults').innerHTML = html;
}

// If user clears the search bar, revert to default list
const searchInput = document.getElementById('vectorSearchQuery');
if (searchInput) {
    searchInput.addEventListener('input', function() {
        if (!this.value.trim()) {
            isVectorSearch = false;
            document.getElementById('vectorSearchResults').innerHTML = '';
            loadMemories();
        }
    });
}

function getRelationshipBadgeColor(relationshipType) {
    const type = relationshipType.toLowerCase();
    switch (type) {
        case 'explains':
        case 'explanation-of':
            return 'bg-info';
        case 'example-of':
        case 'example':
            return 'bg-success';
        case 'related-to':
        case 'related':
            return 'bg-primary';
        case 'supersedes':
        case 'replaces':
            return 'bg-warning';
        case 'depends-on':
        case 'requires':
            return 'bg-danger';
        case 'chunk-of':
        case 'part-of':
            return 'bg-secondary';
        default:
            return 'bg-dark';
    }
}
</script>
} 